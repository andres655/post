<div class="@BackdropClass" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="@TitleId">
    <div class="@DialogClass">
        <div class="@ContentClass">
            @if (ShowHeader)
            {
                <div class="@HeaderClass">
                    @if (HeaderContent is not null)
                    {
                        @HeaderContent
                    }
                    else
                    {
                        <h5 id="@TitleId" class="modal-title">@Title</h5>
                        @if (OnClose.HasDelegate)
                        {
                            <button type="button" class="btn-close" @onclick="OnClose" aria-label="@CloseLabel"></button>
                        }
                    }
                </div>
            }

            <div class="@BodyClass">
                @ChildContent
            </div>

            @if (FooterContent is not null)
            {
                <div class="@FooterClass">
                    @FooterContent
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly string TitleId = $"modal-title-{Guid.NewGuid():N}";

    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string CloseLabel { get; set; } = "Cerrar";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public bool ShowHeader { get; set; } = true;
    [Parameter] public string BackdropClass { get; set; } = "modal fade show d-block";
    [Parameter] public string DialogClass { get; set; } = "modal-dialog modal-dialog-centered";
    [Parameter] public string ContentClass { get; set; } = "modal-content border-0 shadow";
    [Parameter] public string HeaderClass { get; set; } = "modal-header border-0 pb-0";
    [Parameter] public string BodyClass { get; set; } = "modal-body";
    [Parameter] public string FooterClass { get; set; } = "modal-footer border-0 pt-0";
}
