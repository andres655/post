@if (TotalPages > 1 || AlwaysVisible)
{
    <div class="table-pagination" aria-label="@AriaLabel">
        <button type="button" disabled="@IsPreviousDisabled" @onclick="GoPrevious" aria-label="@PreviousLabel">
            <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
        </button>
        <span>@PageLabel @CurrentPage de @TotalPages</span>
        <button type="button" disabled="@IsNextDisabled" @onclick="GoNext" aria-label="@NextLabel">
            <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        </button>
    </div>
}

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool AlwaysVisible { get; set; } = true;
    [Parameter] public string PageLabel { get; set; } = "Pagina";
    [Parameter] public string PreviousLabel { get; set; } = "Pagina anterior";
    [Parameter] public string NextLabel { get; set; } = "Pagina siguiente";
    [Parameter] public string AriaLabel { get; set; } = "Paginacion de tabla";

    private bool IsPreviousDisabled => Disabled || CurrentPage <= 1;
    private bool IsNextDisabled => Disabled || CurrentPage >= TotalPages;

    private async Task GoPrevious()
    {
        if (!IsPreviousDisabled)
            await CurrentPageChanged.InvokeAsync(CurrentPage - 1);
    }

    private async Task GoNext()
    {
        if (!IsNextDisabled)
            await CurrentPageChanged.InvokeAsync(CurrentPage + 1);
    }
}
