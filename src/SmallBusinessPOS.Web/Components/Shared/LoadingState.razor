<div class="@ContainerClass">
    <div class="@SpinnerClass" role="status" aria-label="@Label">
        @if (ShowHiddenLabel)
        {
            <span class="visually-hidden">@Label</span>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Cargando...";
    [Parameter] public string ContainerClass { get; set; } = "loading-state";
    [Parameter] public string SpinnerClass { get; set; } = "loading-state-spinner";
    [Parameter] public bool ShowHiddenLabel { get; set; } = true;
}
