<AppModal Title="@Title"
          ShowHeader="false"
          BackdropClass="@BackdropClass"
          DialogClass="@DialogClass"
          ContentClass="@ContentClass"
          BodyClass="@BodyClass"
          FooterClass="@FooterClass">
    <ChildContent>
        @if (!string.IsNullOrWhiteSpace(IconClass))
        {
            <i class="@IconClass" aria-hidden="true"></i>
        }

        @if (MessageContent is not null)
        {
            @MessageContent
        }
        else if (!string.IsNullOrWhiteSpace(Message))
        {
            <p>@Message</p>
        }
    </ChildContent>
    <FooterContent>
        <button class="@CancelButtonClass" @onclick="OnCancel">@CancelText</button>
        <SaveButton CssClass="@ConfirmButtonClass"
                    Text="@ConfirmText"
                    SavingText="@SavingText"
                    Saving="@Saving"
                    Disabled="@Disabled"
                    OnClick="@OnConfirm" />
    </FooterContent>
</AppModal>

@code {
    [Parameter] public string Title { get; set; } = "Confirmar";
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? MessageContent { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public bool Saving { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string CancelText { get; set; } = "Cancelar";
    [Parameter] public string ConfirmText { get; set; } = "Confirmar";
    [Parameter] public string? SavingText { get; set; }
    [Parameter] public string CancelButtonClass { get; set; } = "shared-confirm-cancel";
    [Parameter] public string ConfirmButtonClass { get; set; } = "shared-confirm-danger";
    [Parameter] public string IconClass { get; set; } = "fa-solid fa-triangle-exclamation shared-confirm-icon";
    [Parameter] public string BackdropClass { get; set; } = "app-modal-backdrop";
    [Parameter] public string DialogClass { get; set; } = "app-modal-dialog shared-confirm-dialog";
    [Parameter] public string ContentClass { get; set; } = "app-modal-content";
    [Parameter] public string BodyClass { get; set; } = "app-modal-body shared-confirm-body";
    [Parameter] public string FooterClass { get; set; } = "app-modal-footer shared-confirm-footer";
}
