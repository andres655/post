@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="shared-error-alert" role="alert">
        <span class="shared-error-alert-icon" aria-hidden="true">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </span>
        <div class="shared-error-alert-copy">
            <strong>No se pudo completar la operaci&oacute;n</strong>
            <span>@Message</span>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? Message { get; set; }
}
