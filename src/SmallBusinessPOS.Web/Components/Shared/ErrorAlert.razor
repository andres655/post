@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
        <span class="bi bi-exclamation-triangle-fill" aria-hidden="true"></span>
        <div>@Message</div>
    </div>
}

@code {
    [Parameter]
    public string? Message { get; set; }
}
