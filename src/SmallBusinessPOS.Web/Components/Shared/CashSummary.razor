@using SmallBusinessPOS.Application.Features.CashSessions.GetCashSessionSummary

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <strong>@Summary.CashRegisterCode - @Summary.CashRegisterName</strong>
        <span class="badge bg-success-subtle text-success">@Summary.Status</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6 col-xl-4"><small class="text-muted">Apertura</small><div class="fs-5 fw-bold">RD$ @Summary.OpeningAmount.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Ventas en efectivo</small><div class="fs-5 fw-bold">RD$ @Summary.CashSales.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Otros ingresos</small><div class="fs-5 fw-bold">RD$ @Summary.OtherIncome.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Gastos</small><div class="fs-5 fw-bold">RD$ @Summary.Expenses.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Retiros</small><div class="fs-5 fw-bold">RD$ @Summary.Withdrawals.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Reembolsos</small><div class="fs-5 fw-bold">RD$ @Summary.Refunds.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Efectivo esperado</small><div class="fs-5 fw-bold">RD$ @Summary.ExpectedCash.ToString("N2")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Efectivo contado</small><div class="fs-5 fw-bold">@(CountedCash.HasValue ? $"RD$ {CountedCash.Value:N2}" : "-")</div></div>
            <div class="col-6 col-xl-4"><small class="text-muted">Diferencia</small><div class="fs-5 fw-bold @(Difference.GetValueOrDefault() < 0 ? "text-danger" : "text-success")">@(Difference.HasValue ? $"RD$ {Difference.Value:N2}" : "-")</div></div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CashSessionSummaryDto Summary { get; set; } = null!;

    [Parameter]
    public decimal? CountedCash { get; set; }

    [Parameter]
    public decimal? Difference { get; set; }
}
