@using SmallBusinessPOS.Application.Features.CashSessions.GetCashSessionSummary

<section class="cash-summary-card" aria-label="Resumen de caja">
    <header class="cash-summary-header">
        <span class="cash-summary-title">
            <span class="cash-summary-icon" aria-hidden="true">
                <i class="fa-solid fa-cash-register"></i>
            </span>
            <span>
                <strong>@Summary.CashRegisterCode - @Summary.CashRegisterName</strong>
                <small>Resumen operativo de caja</small>
            </span>
        </span>
        <span class="cash-summary-status">@Summary.Status</span>
    </header>

    <div class="cash-summary-grid">
        <div class="cash-summary-metric"><small>Apertura</small><strong>RD$ @Summary.OpeningAmount.ToString("N2")</strong></div>
        <div class="cash-summary-metric"><small>Ventas en efectivo</small><strong>RD$ @Summary.CashSales.ToString("N2")</strong></div>
        <div class="cash-summary-metric"><small>Otros ingresos</small><strong>RD$ @Summary.OtherIncome.ToString("N2")</strong></div>
        <div class="cash-summary-metric"><small>Gastos</small><strong>RD$ @Summary.Expenses.ToString("N2")</strong></div>
        <div class="cash-summary-metric"><small>Retiros</small><strong>RD$ @Summary.Withdrawals.ToString("N2")</strong></div>
        <div class="cash-summary-metric"><small>Reembolsos</small><strong>RD$ @Summary.Refunds.ToString("N2")</strong></div>
        <div class="cash-summary-metric is-emphasis"><small>Efectivo esperado</small><strong>RD$ @Summary.ExpectedCash.ToString("N2")</strong></div>
        <div class="cash-summary-metric is-emphasis"><small>Efectivo contado</small><strong>@(CountedCash.HasValue ? $"RD$ {CountedCash.Value:N2}" : "-")</strong></div>
        <div class="cash-summary-metric is-emphasis @DifferenceStateClass"><small>Diferencia</small><strong>@(Difference.HasValue ? $"RD$ {Difference.Value:N2}" : "-")</strong></div>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public CashSessionSummaryDto Summary { get; set; } = null!;

    [Parameter]
    public decimal? CountedCash { get; set; }

    [Parameter]
    public decimal? Difference { get; set; }

    private string DifferenceStateClass => Difference.GetValueOrDefault() < 0 ? "is-negative" : "is-positive";
}
