@page "/inventory"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.Inventory.AdjustInventory
@using SmallBusinessPOS.Application.Features.Inventory.GetInventoryMovements
@using SmallBusinessPOS.Application.Features.Inventory.GetInventoryOverview
@using SmallBusinessPOS.Application.Features.Inventory.SetMinimumStock
@using SmallBusinessPOS.Application.Interfaces
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Domain.Enums

@inject GetPosContextHandler PosContextHandler
@inject GetInventoryOverviewHandler OverviewHandler
@inject GetInventoryMovementsHandler MovementsHandler
@inject AdjustInventoryHandler AdjustHandler
@inject SetMinimumStockHandler MinimumHandler
@inject ICurrentUserService CurrentUser
@inject NavigationManager Navigation

<PageTitle>Inventario</PageTitle>

<div class="inventory-screen">
    <PageHeader Title="Gestion de Inventario"
                IconClass="fa-solid fa-boxes-stacked"
                HeadingLevel="1"
                HeaderClass="inventory-hero"
                TitleBlockClass="inventory-title-block"
                IconContainerClass="inventory-title-icon">
        <SubtitleContent>
            <p>Supervisa y controla los niveles de stock en tiempo real.</p>
        </SubtitleContent>
        <Actions>
            <AuthorizeView Roles="Administrator">
                <Authorized>
                    <button type="button" class="inventory-primary-action" @onclick="GoToProducts">
                        <i class="fa-solid fa-plus" aria-hidden="true"></i>
                        Anadir Producto
                    </button>
                </Authorized>
            </AuthorizeView>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="inventory-alert success">@_success</div>
    }

    <section class="inventory-kpis" aria-label="Resumen de inventario">
        <article class="inventory-kpi">
            <div>
                <span>Total Productos</span>
                <strong>@TotalProducts.ToString("N0")</strong>
                <small><i class="fa-solid fa-arrow-up" aria-hidden="true"></i> Catalogo visible</small>
            </div>
            <i class="fa-regular fa-clipboard-check" aria-hidden="true"></i>
        </article>
        <article class="inventory-kpi danger">
            <div>
                <span>Stock Bajo</span>
                <strong>@LowStockCount.ToString("N0")</strong>
                <small>Accion requerida</small>
            </div>
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
        </article>
        <article class="inventory-kpi">
            <div>
                <span>Unidades</span>
                <strong>@TotalUnits.ToString("N0")</strong>
                <small>Existencia total</small>
            </div>
            <i class="fa-solid fa-boxes-stacked" aria-hidden="true"></i>
        </article>
        <article class="inventory-kpi">
            <div>
                <span>Agotados</span>
                <strong>@OutOfStockCount.ToString("N0")</strong>
                <small>Sin movimiento</small>
            </div>
            <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
        </article>
    </section>

    <section class="inventory-toolbar" aria-label="Filtros de inventario">
        <div class="inventory-search">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <InputText aria-label="Buscar inventario por SKU o nombre de producto" placeholder="SKU, nombre de producto..." @bind-Value="_searchTerm" @bind-Value:after="LoadInventoryAsync" />
        </div>
        <button type="button" class="inventory-filter-button" @onclick="LoadInventoryAsync">
            <i class="fa-solid fa-rotate" aria-hidden="true"></i>
            Actualizar
        </button>
        <div class="inventory-segmented" aria-label="Filtro rapido por estado de inventario">
            <button type="button" class="@(!_lowStockOnly ? "active" : null)" @onclick="() => SetLowStockFilterAsync(false)">Todos</button>
            <button type="button" class="@(_lowStockOnly ? "active" : null)" @onclick="() => SetLowStockFilterAsync(true)">Bajo</button>
            <button type="button" disabled title="Filtro no disponible todavia">Agotado</button>
        </div>
    </section>

    @if (_loading)
    {
        <LoadingState ContainerClass="inventory-loading" ShowHiddenLabel="false" />
    }
    else
    {
        <section class="inventory-layout">
            <div class="inventory-table-card">
                <div class="table-responsive">
                    <table class="inventory-table">
                        <caption>Productos con existencias, stock minimo, estado y acciones de inventario</caption>
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Producto</th>
                                <th>Unidad</th>
                                <th class="text-end">Stock</th>
                                <th class="text-end">Minimo</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in PagedItems)
                            {
                                <tr class="@(_selected?.ProductId == item.ProductId ? "selected" : null)">
                                    <td data-label="SKU"><span class="inventory-sku">@item.ProductCode</span></td>
                                    <td data-label="Producto">
                                        <div class="inventory-product-cell">
                                            <span class="inventory-product-thumb">@Initials(item.ProductName)</span>
                                            <strong>@item.ProductName</strong>
                                        </div>
                                    </td>
                                    <td data-label="Unidad">@item.UnitOfMeasure</td>
                                    <td class="text-end @(item.IsLowStock ? "inventory-danger-text" : null)" data-label="Stock">@item.Quantity.ToString("N2")</td>
                                    <td class="text-end" data-label="Minimo">@item.MinimumQuantity.ToString("N2")</td>
                                    <td data-label="Estado">
                                        <span class="inventory-status @GetStatusClass(item)">@GetStatusText(item)</span>
                                    </td>
                                    <td class="text-end inventory-actions" data-label="Acciones">
                                        <button type="button" class="inventory-icon-action" title="Movimientos" aria-label="Ver movimientos de @item.ProductName" @onclick="() => SelectProductAsync(item)">
                                            <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
                                        </button>
                                        <AuthorizeView Roles="Supervisor,Administrator">
                                            <button type="button" class="inventory-icon-action" title="Ajustar" aria-label="Ajustar inventario de @item.ProductName" @onclick="() => OpenAdjust(item)">
                                                <i class="fa-solid fa-sliders" aria-hidden="true"></i>
                                            </button>
                                            <button type="button" class="inventory-icon-action warning" title="Stock minimo" aria-label="Cambiar stock minimo de @item.ProductName" @onclick="() => OpenMinimum(item)">
                                                <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
                                            </button>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_items.Count == 0)
                {
                    <EmptyState Title="No hay productos con inventario para mostrar."
                                Description="Ajusta la busqueda o registra productos que controlen existencia."
                                IconClass="fa-solid fa-box-open"
                                ContainerClass="inventory-empty"
                                IconContainerClass="inventory-empty-icon" />
                }

                <div class="inventory-table-footer">
                    <span>@InventoryCountText</span>
                    <TablePager CurrentPage="_page" TotalPages="TotalPages" CurrentPageChanged="SetPage" />
                </div>
            </div>

            <aside class="inventory-movements">
                <div class="inventory-panel-header">
                    <div>
                        <strong>Movimientos</strong>
                        <span>@(_selected is null ? "Selecciona un producto" : _selected.ProductCode)</span>
                    </div>
                </div>

                @if (_selected is null)
                {
                    <EmptyState Title="Selecciona un producto"
                                Description="Veras sus ultimos movimientos y cambios de existencia."
                                IconClass="fa-solid fa-clock-rotate-left"
                                ContainerClass="inventory-panel-empty"
                                IconContainerClass="inventory-empty-icon" />
                }
                else if (_movementsLoading)
                {
                    <LoadingState ContainerClass="inventory-panel-empty"
                                  SpinnerClass="spinner-border spinner-border-sm text-success"
                                  ShowHiddenLabel="false" />
                }
                else if (_movements.Count == 0)
                {
                    <div class="inventory-panel-empty">Sin movimientos registrados.</div>
                }
                else
                {
                    <div class="inventory-movement-list">
                        @foreach (var movement in _movements)
                        {
                            <article class="inventory-movement">
                                <div>
                                    <strong>@GetMovementName(movement.MovementType)</strong>
                                    <span>@movement.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                                </div>
                                <p>@movement.PreviousQuantity.ToString("N2") -> @movement.NewQuantity.ToString("N2") &middot; @movement.Quantity.ToString("N2")</p>
                                @if (!string.IsNullOrWhiteSpace(movement.Reason))
                                {
                                    <small>@movement.Reason</small>
                                }
                            </article>
                        }
                    </div>
                }
            </aside>
        </section>
    }
</div>

@if (_adjustItem is not null)
{
    <AppModal Title="Ajuste manual"
              OnClose="CloseForms"
              BackdropClass="modal fade show d-block inventory-modal-backdrop"
              ContentClass="modal-content border-0 shadow inventory-modal"
              HeaderClass="modal-header border-0 pb-0 inventory-modal-header"
              BodyClass="modal-body inventory-modal-body"
              FooterClass="modal-footer border-0 pt-0 inventory-modal-footer">
        <ChildContent>
                    <p class="inventory-modal-product"><code>@_adjustItem.ProductCode</code> @_adjustItem.ProductName</p>
                    <label class="form-label" for="adjustQuantity">Cantidad a ajustar</label>
                    <input class="form-control"
                           id="adjustQuantity"
                           type="number"
                           min="0"
                           step="0.01"
                           @bind="_adjustQuantity"
                           @bind:event="oninput" />
                    <small class="text-muted">Escribe la cantidad en positivo. El checkbox define si entra o sale del inventario.</small>

                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="adjustDecrease" @bind="_adjustIsDecrease" />
                        <label class="form-check-label" for="adjustDecrease">Descontar inventario</label>
                    </div>
                    <small class="text-muted">@AdjustmentDirectionText</small>

                    <label class="form-label mt-3" for="adjustReason">Motivo</label>
                    <InputText class="form-control" id="adjustReason" placeholder="Opcional" @bind-Value="_adjustReason" />
        </ChildContent>
        <FooterContent>
            <button class="btn btn-secondary" @onclick="CloseForms"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i>Cancelar</button>
            <SaveButton Text="Guardar ajuste" Saving="@_saving" IconClass="fa-solid fa-floppy-disk me-1" OnClick="SaveAdjustmentAsync" />
        </FooterContent>
    </AppModal>
}

@if (_minimumItem is not null)
{
    <AppModal Title="Stock minimo"
              OnClose="CloseForms"
              BackdropClass="modal fade show d-block inventory-modal-backdrop"
              ContentClass="modal-content border-0 shadow inventory-modal"
              HeaderClass="modal-header border-0 pb-0 inventory-modal-header"
              BodyClass="modal-body inventory-modal-body"
              FooterClass="modal-footer border-0 pt-0 inventory-modal-footer">
        <ChildContent>
                    <p class="inventory-modal-product"><code>@_minimumItem.ProductCode</code> @_minimumItem.ProductName</p>
                    <label class="form-label" for="minimumQuantity">Minimo</label>
                    <InputNumber class="form-control" id="minimumQuantity" @bind-Value="_minimumQuantity" />
        </ChildContent>
        <FooterContent>
            <button class="btn btn-secondary" @onclick="CloseForms"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i>Cancelar</button>
            <SaveButton Text="Guardar minimo" Saving="@_saving" IconClass="fa-solid fa-floppy-disk me-1" OnClick="SaveMinimumAsync" />
        </FooterContent>
    </AppModal>
}
