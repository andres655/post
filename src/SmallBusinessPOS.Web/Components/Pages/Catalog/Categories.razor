@page "/categories"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Categorías — CajaPyme</PageTitle>

<div class="container-fluid categories-page">
    <PageHeader Title="Categorías"
                Subtitle="Organiza productos para venta e inventario"
                IconClass="fa-solid fa-tags"
                HeaderClass="categories-header"
                TitleBlockClass="categories-title-block"
                IconContainerClass="categories-title-icon"
                TitleClass="mb-0">
        <Actions>
            <button class="btn btn-primary categories-primary-action" @onclick="NuevaCategoria">
                <i class="fa-solid fa-circle-plus me-1"></i>Nueva categoría
            </button>
        </Actions>
    </PageHeader>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible categories-alert danger" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>@_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    <SuccessAlert Message="@_successMessage"
                  CssClass="alert alert-success alert-dismissible categories-alert success"
                  Role="alert"
                  OnClose="@(() => _successMessage = null)" />

    @if (_loading)
    {
        <LoadingState ContainerClass="text-center py-5 categories-loading" />
    }
    else if (_categories is not null)
    {
        <div class="card border-0 shadow-sm categories-table-card">
            <div class="categories-table-header">
                <div>
                    <strong>Catálogo de categorías</strong>
                    <small>@CategoriesCountText</small>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle categories-table">
                    <caption>Categorías, orden, productos asociados, estado y acciones</caption>
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th class="text-center">Orden</th>
                            <th class="text-center">Productos</th>
                            <th class="text-center">Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in PagedCategories)
                        {
                            <tr>
                                <td data-label="Nombre">
                                    <div class="categories-name-cell">
                                        <span class="categories-avatar" aria-hidden="true">@Initials(cat.Name)</span>
                                        <strong>@cat.Name</strong>
                                    </div>
                                </td>
                                <td class="text-muted categories-description" data-label="Descripción">@(cat.Description ?? "—")</td>
                                <td class="text-center" data-label="Orden">
                                    <span class="categories-order-chip">@cat.SortOrder</span>
                                </td>
                                <td class="text-center" data-label="Productos">
                                    <span class="categories-count-chip">@cat.ProductCount</span>
                                </td>
                                <td class="text-center" data-label="Estado">
                                    @if (cat.IsActive)
                                    {
                                        <span class="categories-status active">Activa</span>
                                    }
                                    else
                                    {
                                        <span class="categories-status inactive">Inactiva</span>
                                    }
                                </td>
                                <td class="text-end categories-actions" data-label="Acciones">
                                    <button class="btn btn-sm btn-outline-secondary me-1 categories-icon-action"
                                            title="Editar categoría"
                                            aria-label="Editar categoría @cat.Name"
                                            @onclick="() => EditarCategoria(cat)">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    @if (cat.IsActive)
                                    {
                                        <button class="btn btn-sm btn-outline-danger categories-icon-action danger"
                                                @onclick="() => ConfirmarDeshabilitar(cat)"
                                                title="Deshabilitar"
                                                aria-label="Deshabilitar categoría @cat.Name">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_categories.Count == 0)
                {
                    <EmptyState Title="No hay categorías registradas."
                                Description="Crea la primera para organizar tus productos."
                                IconClass="fa-solid fa-tags"
                                ContainerClass="categories-empty"
                                IconContainerClass="categories-empty-icon" />
                }
            </div>
            @if (_categories.Count > 0)
            {
                <div class="categories-table-footer">
                    <span>@CategoriesCountText</span>
                    <TablePager CurrentPage="_page" TotalPages="TotalPages" CurrentPageChanged="SetPage" />
                </div>
            }
        </div>
    }
</div>

<!-- Modal de creación/edición -->
@if (_mostrarFormulario)
{
    <AppModal Title="@(_editando ? "Editar categoría" : "Nueva categoría")"
              OnClose="CerrarFormulario"
              BackdropClass="modal fade show d-block categories-modal-backdrop"
              DialogClass="modal-dialog modal-dialog-centered"
              ContentClass="modal-content border-0 shadow categories-modal"
              HeaderClass="modal-header border-0 pb-0 categories-modal-header"
              BodyClass="modal-body categories-modal-body"
              FooterClass="modal-footer border-0 pt-0 categories-modal-footer">
        <ChildContent>
            <div class="mb-3 categories-field">
                <label class="form-label fw-semibold" for="categoryName">Nombre <span class="text-danger">*</span></label>
                <input type="text" class="form-control"
                       id="categoryName" @bind="_formNombre" placeholder="Ej: Pollos" maxlength="100" />
            </div>
            <div class="mb-3 categories-field">
                <label class="form-label fw-semibold" for="categoryDescription">Descripción</label>
                <textarea class="form-control" id="categoryDescription" @bind="_formDescripcion" rows="2"
                          placeholder="Descripción opcional" maxlength="500"></textarea>
            </div>
            <div class="mb-3 categories-field">
                <label class="form-label fw-semibold" for="categoryOrder">Orden de visualización</label>
                <input type="number" class="form-control" id="categoryOrder" @bind="_formOrden" min="0" max="9999" />
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger py-2 mb-0 categories-form-alert">
                    <small><i class="fa-solid fa-circle-exclamation me-1"></i>@_formError</small>
                </div>
            }
        </ChildContent>
        <FooterContent>
            <button class="btn btn-secondary" @onclick="CerrarFormulario">Cancelar</button>
            <SaveButton Saving="@_saving" OnClick="GuardarCategoria" />
        </FooterContent>
    </AppModal>
}

<!-- Modal de confirmación deshabilitar -->
@if (_categoriaADeshabilitar is not null)
{
    <ConfirmDialog Title="Deshabilitar categoría"
                   BackdropClass="modal fade show d-block categories-modal-backdrop"
                   DialogClass="modal-dialog modal-dialog-centered modal-sm"
                   ContentClass="modal-content border-0 shadow categories-modal"
                   BodyClass="modal-body text-center py-4 categories-confirm-body"
                   FooterClass="modal-footer border-0 pt-0 justify-content-center categories-modal-footer"
                   CancelButtonClass="btn btn-secondary"
                   ConfirmButtonClass="btn btn-danger"
                   ConfirmText="Deshabilitar"
                   Saving="@_saving"
                   OnCancel="@(() => _categoriaADeshabilitar = null)"
                   OnConfirm="DeshabilitarCategoria">
        <MessageContent>
            <p>¿Deshabilitar la categoría <strong>@_categoriaADeshabilitar.Name</strong>?</p>
        </MessageContent>
    </ConfirmDialog>
}

