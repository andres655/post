@page "/pos"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using SmallBusinessPOS.Application.Features.CashSessions.CloseCashSession
@using SmallBusinessPOS.Application.Features.CashSessions.DTOs
@using SmallBusinessPOS.Application.Features.CashSessions.GetCurrentCashSession
@using SmallBusinessPOS.Application.Features.CashSessions.OpenCashSession
@using SmallBusinessPOS.Application.Features.Categories.DTOs
@using SmallBusinessPOS.Application.Features.Categories.GetCategories
@using SmallBusinessPOS.Application.Features.PaymentMethods.GetActivePaymentMethods
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Products.DTOs
@using SmallBusinessPOS.Application.Features.Products.GetProducts
@using SmallBusinessPOS.Application.Features.Sales.CreateSale
@using SmallBusinessPOS.Domain.Enums
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject GetCategoriesHandler CategoriesHandler
@inject GetProductsHandler ProductsHandler
@inject GetActivePaymentMethodsHandler PaymentMethodsHandler
@inject GetCurrentCashSessionHandler CurrentSessionHandler
@inject OpenCashSessionHandler OpenSessionHandler
@inject CloseCashSessionHandler CloseSessionHandler
@inject CreateSaleHandler CreateSaleHandler
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>POS</PageTitle>

<div class="container-fluid pos-page">
    <div class="pos-header">
        <div>
            <h2 class="mb-0">Punto de Venta</h2>
            @if (_context is not null)
            {
                <span class="text-muted">@_context.BranchName / Caja @_context.CashRegisterCode</span>
            }
        </div>
        <div class="d-flex align-items-center flex-wrap gap-2">
            <AuthorizeView Roles="Supervisor,Administrator">
                <Authorized>
                    <button class="btn btn-outline-secondary" @onclick="GoToCancellationHistory">
                        Historial / Reimpresion
                    </button>
                </Authorized>
            </AuthorizeView>
            <button class="btn btn-outline-primary" @onclick="GoToCash">Caja</button>
        </div>
    </div>

    <ErrorAlert Message="@_error" />

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success d-flex justify-content-between align-items-center">
            <span>@_success</span>
            @if (_lastSaleId.HasValue)
            {
                <button class="btn btn-sm btn-outline-success" @onclick="PrintLastSaleAsync">
                    Imprimir ticket
                </button>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (_context is not null)
    {
        <div class="mb-3">
            @if (_currentSession is null)
            {
                <div class="alert alert-warning d-flex justify-content-between align-items-center flex-wrap gap-2 mb-0">
                    <div>
                        <strong>Antes de cobrar</strong>
                        <div class="small">Abre la caja con un monto inicial para registrar el turno y dejar todo listo para vender.</div>
                    </div>
                    <button class="btn btn-sm btn-outline-warning" @onclick="OpenSessionAsync">Abrir caja</button>
                </div>
            }
            else if (_cart.Count == 0)
            {
                <div class="alert alert-info mb-0">Busca productos y agrégalos al carrito para comenzar la venta.</div>
            }
            else if (Paid < Total)
            {
                <div class="alert alert-warning mb-0">Completa los pagos para poder confirmar la venta.</div>
            }
        </div>

        <div class="pos-shell">
            <section class="pos-products">
                <div class="card border-0 pos-panel mb-3">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <div>
                                <div class="kpi-label">Estado operativo</div>
                                <div class="h5 mb-0">@_context.BusinessName</div>
                                <small class="text-muted">@_todayLocal.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>

                            @if (_currentSession is null)
                            {
                                <div class="d-flex gap-2 align-items-end flex-wrap">
                                    <div>
                                        <label class="form-label mb-1">Efectivo inicial</label>
                                        <div class="input-group">
                                            <span class="input-group-text">RD$</span>
                                            <input class="form-control" type="number" min="0" step="0.01" @bind="_openingAmount" />
                                        </div>
                                    </div>
                                    <button class="btn btn-success" @onclick="OpenSessionAsync">Abrir caja</button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex gap-3 align-items-center flex-wrap">
                                    <div>
                                        <span class="badge bg-success-subtle text-success mb-1">Caja abierta</span>
                                        <div class="fw-bold">Esperado: RD$ @_currentSession.ExpectedClosingBalance.ToString("N2")</div>
                                    </div>
                                    <button class="btn btn-outline-danger" @onclick="() => _showCloseModal = true">Cerrar caja</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card border-0 pos-panel">
                    <div class="card-body">
                        <div class="row g-2 align-items-center mb-3">
                            <div class="col-12 col-xl-5">
                                <input class="form-control form-control-lg"
                                       placeholder="Buscar producto por nombre o codigo"
                                       @bind="_search"
                                       @bind:after="FilterProducts" />
                            </div>
                            <div class="col-12 col-xl-7">
                                <div class="category-strip">
                                    <button class="btn category-pill @(string.IsNullOrEmpty(_selectedCategoryId) ? "active" : string.Empty)"
                                            @onclick="() => SelectCategory(null)">
                                        Todas
                                    </button>
                                    @foreach (var category in _categories)
                                    {
                                        <button class="btn category-pill @(_selectedCategoryId == category.Id.ToString() ? "active" : string.Empty)"
                                                @onclick="() => SelectCategory(category.Id)">
                                            @category.Name
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="product-grid">
                            @foreach (var product in _filteredProducts)
                            {
                                <button class="product-tile" @onclick="() => AddToCart(product)">
                                    <span class="product-name">@product.Name</span>
                                    <span class="product-code">@product.Code</span>
                                    <span class="product-price">RD$ @product.SalePrice.ToString("N2")</span>
                                </button>
                            }

                            @if (_filteredProducts.Count == 0)
                            {
                                <div class="text-center text-muted py-5">No hay productos para estos filtros.</div>
                            }
                        </div>
                    </div>
                </div>
            </section>

            <aside class="pos-cart">
                <div class="card border-0 pos-panel cart-card">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span>Venta actual</span>
                        <span class="badge bg-primary-subtle text-primary">@_cart.Count items</span>
                    </div>

                    <div class="cart-lines">
                        @if (_cart.Count == 0)
                        {
                            <div class="empty-cart">
                                <div class="h6 mb-1">Sin productos</div>
                                <div class="text-muted">Toca un producto para agregarlo.</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var line in _cart)
                            {
                                <div class="cart-line">
                                    <div class="d-flex justify-content-between gap-2">
                                        <div class="min-w-0">
                                            <div class="fw-semibold text-truncate">@line.Name</div>
                                            <small class="text-muted">RD$ @line.UnitPrice.ToString("N2")</small>
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFromCart(line.ProductId)">x</button>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-outline-secondary" @onclick="() => ChangeQty(line.ProductId, -1)">-</button>
                                            <button class="btn btn-outline-secondary qty-display" disabled>@line.Quantity.ToString("N2")</button>
                                            <button class="btn btn-outline-secondary" @onclick="() => ChangeQty(line.ProductId, 1)">+</button>
                                        </div>
                                        <div class="fw-bold">RD$ @line.LineTotal.ToString("N2")</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="card-body border-top">
                        <div class="summary-row"><span>Subtotal</span><strong>RD$ @Subtotal.ToString("N2")</strong></div>
                        <div class="summary-row">
                            <span>Descuento</span>
                            <input class="form-control form-control-sm amount-input" type="number" min="0" step="0.01" @bind="_discount" @bind:event="oninput" />
                        </div>
                        <div class="summary-row">
                            <span>ITBIS</span>
                            <input class="form-control form-control-sm amount-input" type="number" min="0" step="0.01" @bind="_tax" @bind:event="oninput" />
                        </div>

                        <div class="total-box">
                            <span>Total</span>
                            <strong>RD$ @Total.ToString("N2")</strong>
                        </div>

                        <div class="border rounded p-3 mb-3 bg-light">
                            <div class="small fw-semibold text-uppercase text-muted mb-2">Flujo de venta</div>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill @( _currentSession is not null ? "bg-success" : "bg-secondary" )">1</span>
                                    <span class="@( _currentSession is not null ? "text-success fw-semibold" : "text-muted" )">Abrir caja</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill @( _cart.Count > 0 ? "bg-success" : "bg-secondary" )">2</span>
                                    <span class="@( _cart.Count > 0 ? "text-success fw-semibold" : "text-muted" )">Agregar productos</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill @( Paid >= Total && Total > 0 ? "bg-success" : "bg-secondary" )">3</span>
                                    <span class="@( Paid >= Total && Total > 0 ? "text-success fw-semibold" : "text-muted" )">Completar pagos</span>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-light border mb-3 p-2 small fw-semibold text-dark">
                            @PosFlowGuidance.GetPaymentHint(_currentSession is not null, _cart.Count > 0, Total, Paid)
                        </div>

                        <div class="fw-semibold mb-2">Pagos</div>
                        @foreach (var payment in _payments)
                        {
                            <div class="payment-row">
                                <label class="small">@payment.Name</label>
                                <input class="form-control form-control-sm amount-input" type="number" min="0" step="0.01" @bind="payment.Amount" @bind:event="oninput" />
                            </div>
                        }

                        <div class="payment-status">
                            <div><span>Pagado</span><strong>RD$ @Paid.ToString("N2")</strong></div>
                            <div><span>Cambio</span><strong class="text-success">RD$ @Change.ToString("N2")</strong></div>
                        </div>

                        <button class="btn w-100 btn-lg checkout-btn @( PosFlowGuidance.CanConfirmCheckout(_currentSession is not null, _cart.Count > 0, Total, Paid) ? "btn-success" : "btn-outline-secondary" )" @onclick="ConfirmSaleAsync" disabled="@(!PosFlowGuidance.CanConfirmCheckout(_currentSession is not null, _cart.Count > 0, Total, Paid))">
                            @PosFlowGuidance.GetCheckoutLabel(_currentSession is not null, _cart.Count > 0, Total, Paid)
                        </button>
                    </div>
                </div>
            </aside>
        </div>

        @if (_showCloseModal)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header">
                            <h5 class="modal-title">Cerrar caja</h5>
                            <button class="btn-close" @onclick="() => _showCloseModal = false"></button>
                        </div>
                        <div class="modal-body">
                            <label class="form-label">Efectivo contado</label>
                            <input class="form-control" type="number" min="0" step="0.01" @bind="_countedAmount" />
                            <label class="form-label mt-2">Notas</label>
                            <textarea class="form-control" rows="2" @bind="_closeNotes"></textarea>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="() => _showCloseModal = false">Cancelar</button>
                            <button class="btn btn-danger" @onclick="CloseSessionAsync">Cerrar caja</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;

    private PosContextDto? _context;
    private CashSessionDto? _currentSession;
    private decimal _openingAmount;
    private bool _showCloseModal;
    private decimal _countedAmount;
    private string? _closeNotes;

    private readonly DateTime _todayLocal = DateTime.Now;

    private List<CategoryDto> _categories = [];
    private List<ProductSummaryDto> _products = [];
    private List<ProductSummaryDto> _filteredProducts = [];
    private readonly List<CartLine> _cart = [];
    private readonly List<PaymentLine> _payments = [];

    private string _search = string.Empty;
    private string? _selectedCategoryId;

    private decimal _discount;
    private decimal _tax;
    private Guid? _lastSaleId;

    private bool _canSell => PosFlowGuidance.CanAttemptCheckout(_currentSession is not null, _cart.Count > 0, Total, Paid);

    private decimal Subtotal => _cart.Sum(x => x.LineTotal);
    private decimal Total => Subtotal - _discount + _tax;
    private decimal Paid => _payments.Sum(p => p.Amount);
    private decimal Change
    {
        get
        {
            var cash = _payments
                .Where(p => p.Type == PaymentMethodType.Cash)
                .Sum(p => p.Amount);
            return cash > Total ? cash - Total : 0m;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _success = null;

        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _context = contextResult.Value;

        var categoriesResult = await CategoriesHandler.HandleAsync(new GetCategoriesQuery(_context.BusinessId));
        if (categoriesResult.IsSuccess)
            _categories = categoriesResult.Value;

        var productsResult = await ProductsHandler.HandleAsync(new GetProductsQuery(_context.BusinessId));
        if (productsResult.IsSuccess)
        {
            _products = productsResult.Value;
            _filteredProducts = _products;
        }

        var methodsResult = await PaymentMethodsHandler.HandleAsync(new GetActivePaymentMethodsQuery(_context.BusinessId));
        if (methodsResult.IsSuccess)
        {
            _payments.Clear();
            foreach (var method in methodsResult.Value)
                _payments.Add(new PaymentLine(method.Id, method.Code, method.Name, method.Type));
        }

        await RefreshSessionAsync();
        _loading = false;
    }

    private async Task RefreshSessionAsync()
    {
        if (_context is null)
            return;

        var sessionResult = await CurrentSessionHandler.HandleAsync(new GetCurrentCashSessionQuery(_context.CashRegisterId));
        if (sessionResult.IsSuccess)
            _currentSession = sessionResult.Value;
        else
            _currentSession = null;
    }

    private void SelectCategory(Guid? categoryId)
    {
        _selectedCategoryId = categoryId?.ToString();
        FilterProducts();
    }

    private void FilterProducts()
    {
        IEnumerable<ProductSummaryDto> query = _products;

        if (!string.IsNullOrWhiteSpace(_selectedCategoryId))
        {
            var categoryName = _categories
                .Where(c => c.Id.ToString() == _selectedCategoryId)
                .Select(c => c.Name)
                .FirstOrDefault();

            if (!string.IsNullOrWhiteSpace(categoryName))
                query = query.Where(p => p.CategoryName == categoryName);
        }

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var term = _search.Trim().ToLowerInvariant();
            query = query.Where(p => p.Name.ToLower().Contains(term) || p.Code.ToLower().Contains(term));
        }

        _filteredProducts = query.ToList();
    }

    private void AddToCart(ProductSummaryDto product)
    {
        var existing = _cart.FirstOrDefault(x => x.ProductId == product.Id);
        if (existing is not null)
        {
            existing.Quantity += 1;
            return;
        }

        _cart.Add(new CartLine
        {
            ProductId = product.Id,
            Name = product.Name,
            UnitPrice = product.SalePrice,
            Quantity = 1m
        });
    }

    private void ChangeQty(Guid productId, int delta)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item is null)
            return;

        item.Quantity += delta;
        if (item.Quantity <= 0)
            _cart.Remove(item);
    }

    private void RemoveFromCart(Guid productId)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item is not null)
            _cart.Remove(item);
    }

    private async Task OpenSessionAsync()
    {
        if (_context is null)
            return;

        var result = await OpenSessionHandler.HandleAsync(new OpenCashSessionCommand(
            _context.BusinessId,
            _context.BranchId,
            _context.CashRegisterId,
            _openingAmount), await GetCurrentUserAsync());

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            return;
        }

        _success = "Caja abierta correctamente.";
        _openingAmount = 0;
        await RefreshSessionAsync();
    }

    private async Task CloseSessionAsync()
    {
        if (_currentSession is null)
            return;

        var result = await CloseSessionHandler.HandleAsync(new CloseCashSessionCommand(
            _currentSession.Id,
            _countedAmount,
            _closeNotes), await GetCurrentUserAsync());

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            return;
        }

        _success = $"Caja cerrada. Diferencia: RD$ {result.Value.Difference?.ToString("N2")}";
        _showCloseModal = false;
        _countedAmount = 0;
        _closeNotes = null;
        await RefreshSessionAsync();
    }

    private async Task ConfirmSaleAsync()
    {
        if (_context is null || _currentSession is null)
            return;

        var lines = _cart.Select(c => new CreateSaleLine(c.ProductId, c.Quantity, c.UnitPrice)).ToList();
        var payments = BuildSalePayments();
        if (payments is null)
            return;

        var result = await CreateSaleHandler.HandleAsync(new CreateSaleCommand(
            _context.BusinessId,
            _context.BranchId,
            _context.CashRegisterId,
            SaleType.Counter,
            _discount,
            _tax,
            lines,
            payments), await GetCurrentUserAsync());

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            return;
        }

        _success = $"Venta {result.Value.Number} confirmada. Total RD$ {result.Value.Total:N2}";
        _lastSaleId = result.Value.SaleId;
        await PrintLastSaleAsync();

        _cart.Clear();
        _discount = 0;
        _tax = 0;
        foreach (var payment in _payments)
            payment.Amount = 0;

        await RefreshSessionAsync();
    }

    private List<CreateSalePayment>? BuildSalePayments()
    {
        var enteredPayments = _payments
            .Where(p => p.Amount > 0)
            .Select(p => new PaymentLineSnapshot(
                p.PaymentMethodId,
                p.Code,
                p.Name,
                p.Type,
                Math.Round(p.Amount, 2, MidpointRounding.AwayFromZero)))
            .ToList();

        var total = Math.Round(Total, 2, MidpointRounding.AwayFromZero);
        var paid = enteredPayments.Sum(p => p.Amount);
        var overpaid = paid - total;

        if (paid < total)
        {
            _error = $"Faltan RD$ {(total - paid):N2} para cubrir el total de la venta.";
            return null;
        }

        if (overpaid > 0m)
        {
            var cashPayment = enteredPayments.FirstOrDefault(p => IsCashPayment(p) && p.Amount >= overpaid);
            if (cashPayment is null)
            {
                _error = "El pago excede el total. Solo se puede devolver cambio desde efectivo.";
                return null;
            }

            cashPayment.Amount -= overpaid;
        }

        return enteredPayments
            .Where(p => p.Amount > 0)
            .Select(p => new CreateSalePayment(p.PaymentMethodId, p.Amount))
            .ToList();
    }

    private static bool IsCashPayment(PaymentLineSnapshot payment) =>
        payment.Type == PaymentMethodType.Cash
        || payment.Code.Equals("CASH", StringComparison.OrdinalIgnoreCase)
        || payment.Code.Equals("EFECTIVO", StringComparison.OrdinalIgnoreCase)
        || payment.Name.Contains("efectivo", StringComparison.OrdinalIgnoreCase)
        || payment.Name.Contains("cash", StringComparison.OrdinalIgnoreCase);

    private async Task PrintLastSaleAsync()
    {
        if (_lastSaleId is null)
            return;

        await JS.InvokeVoidAsync("printReceipt", $"/api/receipts/sale/{_lastSaleId.Value}");
    }

    private void GoToCancellationHistory() => Navigation.NavigateTo("/sales/cancellations");
    private void GoToCash() => Navigation.NavigateTo("/cash/current");

    private async Task<string?> GetCurrentUserAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }

    private sealed class CartLine
    {
        public Guid ProductId { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal LineTotal => Quantity * UnitPrice;
    }

    private sealed class PaymentLine(Guid paymentMethodId, string code, string name, PaymentMethodType type)
    {
        public Guid PaymentMethodId { get; } = paymentMethodId;
        public string Code { get; } = code;
        public string Name { get; } = name;
        public PaymentMethodType Type { get; } = type;
        public decimal Amount { get; set; }
    }

    private sealed class PaymentLineSnapshot(Guid paymentMethodId, string code, string name, PaymentMethodType type, decimal amount)
    {
        public Guid PaymentMethodId { get; } = paymentMethodId;
        public string Code { get; } = code;
        public string Name { get; } = name;
        public PaymentMethodType Type { get; } = type;
        public decimal Amount { get; set; } = amount;
    }
}
