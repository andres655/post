@page "/sales/returns"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SmallBusinessPOS.Application.Features.PaymentMethods.GetActivePaymentMethods
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Sales.GetSaleForReturn
@using SmallBusinessPOS.Application.Features.Sales.RegisterSaleReturn
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject GetActivePaymentMethodsHandler PaymentMethodsHandler
@inject GetSaleForReturnHandler GetSaleForReturnHandler
@inject RegisterSaleReturnHandler RegisterReturnHandler
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Devoluciones - CajaPyme</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Devoluciones parciales</h2>
            @if (_context is not null)
            {
                <div class="text-muted small">@_context.BusinessName / @_context.BranchName</div>
            }
        </div>
    </div>

    <ErrorAlert Message="@_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <label class="form-label">Numero de venta</label>
            <div class="input-group">
                <input class="form-control" @bind="_saleNumber" placeholder="PRIN-C01-20260718-000001" />
                <button class="btn btn-primary" @onclick="SearchSaleAsync">
                    <i class="fa-solid fa-magnifying-glass me-1"></i>Buscar
                </button>
            </div>
        </div>
    </div>

    @if (_sale is not null)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <strong>@_sale.Number</strong>
                <span class="text-muted ms-2">@_sale.CustomerName - Total RD$ @_sale.Total.ToString("N2")</span>
            </div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Vendido</th>
                            <th class="text-end">Devuelto</th>
                            <th class="text-end">Disponible</th>
                            <th class="text-end">A devolver</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _sale.Lines)
                        {
                            <tr>
                                <td>
                                    <code>@line.ProductCode</code>
                                    <div class="fw-semibold">@line.ProductName</div>
                                </td>
                                <td class="text-end">@line.SoldQuantity.ToString("N2")</td>
                                <td class="text-end">@line.ReturnedQuantity.ToString("N2")</td>
                                <td class="text-end">@line.AvailableQuantity.ToString("N2")</td>
                                <td class="text-end">
                                    <input class="form-control text-end ms-auto"
                                           style="max-width:120px"
                                           type="number"
                                           min="0"
                                           max="@line.AvailableQuantity"
                                           step="0.01"
                                           value="@GetReturnQuantity(line.SaleDetailId)"
                                           @onchange="args => SetReturnQuantity(line.SaleDetailId, args.Value)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-body border-top">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Metodo de reembolso</label>
                        <select class="form-select" @bind="_refundPaymentMethodId">
                            @foreach (var payment in _paymentMethods)
                            {
                                <option value="@payment.Id.ToString()">@payment.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Referencia</label>
                        <input class="form-control" @bind="_refundReference" placeholder="Obligatoria si no es efectivo" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Motivo</label>
                        <input class="form-control" @bind="_reason" />
                    </div>
                    <div class="col-12 d-flex justify-content-between align-items-center">
                        <strong>Total a devolver: RD$ @ReturnTotal.ToString("N2")</strong>
                        <button class="btn btn-danger" disabled="@(ReturnTotal <= 0)" @onclick="RegisterReturnAsync">
                            <i class="fa-solid fa-rotate-left me-1"></i>Registrar devolucion
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private PosContextDto? _context;
    private string _saleNumber = string.Empty;
    private SaleForReturnDto? _sale;
    private List<PaymentMethodDto> _paymentMethods = [];
    private readonly Dictionary<Guid, decimal> _returnQuantities = [];
    private string? _refundPaymentMethodId;
    private string? _refundReference;
    private string _reason = "Devolucion de cliente";
    private string? _error;
    private string? _success;

    private decimal ReturnTotal => _sale is null
        ? 0m
        : _sale.Lines.Sum(line => GetReturnQuantity(line.SaleDetailId) * line.UnitPrice);

    protected override async Task OnInitializedAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            return;
        }

        _context = contextResult.Value;
        var methodsResult = await PaymentMethodsHandler.HandleAsync(new GetActivePaymentMethodsQuery(_context.BusinessId));
        if (methodsResult.IsSuccess)
        {
            _paymentMethods = methodsResult.Value;
            _refundPaymentMethodId = _paymentMethods.FirstOrDefault()?.Id.ToString();
        }
    }

    private async Task SearchSaleAsync()
    {
        if (_context is null)
            return;

        _error = null;
        _success = null;
        _returnQuantities.Clear();

        var result = await GetSaleForReturnHandler.HandleAsync(new GetSaleForReturnQuery(_context.BusinessId, _saleNumber));
        if (result.IsFailure)
        {
            _sale = null;
            _error = result.Error.Description;
            return;
        }

        _sale = result.Value;
    }

    private decimal GetReturnQuantity(Guid saleDetailId) =>
        _returnQuantities.TryGetValue(saleDetailId, out var value) ? value : 0m;

    private void SetReturnQuantity(Guid saleDetailId, object? value)
    {
        if (!decimal.TryParse(Convert.ToString(value), out var quantity) || quantity <= 0)
            _returnQuantities.Remove(saleDetailId);
        else
            _returnQuantities[saleDetailId] = quantity;
    }

    private async Task RegisterReturnAsync()
    {
        if (_sale is null || !Guid.TryParse(_refundPaymentMethodId, out var refundMethodId))
            return;

        var lines = _returnQuantities
            .Where(item => item.Value > 0)
            .Select(item => new RegisterSaleReturnLine(item.Key, item.Value))
            .ToList();

        var result = await RegisterReturnHandler.HandleAsync(new RegisterSaleReturnCommand(
            _sale.SaleId,
            refundMethodId,
            _reason,
            lines,
            _refundReference), await GetCurrentUserAsync());

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            return;
        }

        _success = "Devolucion registrada correctamente.";
        await SearchSaleAsync();
    }

    private async Task<string?> GetCurrentUserAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }
}
