@page "/reports/daily"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Interfaces
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Sales.CancelSale
@using SmallBusinessPOS.Application.Features.Sales.GetDailyReport

@inject GetPosContextHandler PosContextHandler
@inject GetDailyReportHandler DailyReportHandler
@inject CancelSaleHandler CancelSaleHandler
@inject NavigationManager Navigation
@inject ICurrentUserService CurrentUser

<PageTitle>Reporte diario</PageTitle>

<div class="container-fluid report-page daily-report-page">
    <div class="daily-report-header">
        <div class="daily-report-title-block">
            <span class="daily-report-title-icon" aria-hidden="true">
                <i class="fa-solid fa-chart-line"></i>
            </span>
            <div>
                <h2>Reporte diario</h2>
                <span>Ventas, caja, inventario operativo y productos del día.</span>
            </div>
        </div>
        <div class="daily-report-actions">
            <input class="form-control" type="date" @bind="_selectedDate" />
            <button class="btn btn-dark daily-report-primary-action" @onclick="LoadReportAsync"><i class="fa-solid fa-rotate" aria-hidden="true"></i>Actualizar</button>
            <button class="btn btn-outline-secondary daily-report-secondary-action" disabled="@(_report is null)" @onclick='() => Export("csv")'><i class="fa-solid fa-file-csv" aria-hidden="true"></i>CSV</button>
            <button class="btn btn-outline-secondary daily-report-secondary-action" disabled="@(_report is null)" @onclick='() => Export("pdf")'><i class="fa-solid fa-file-pdf" aria-hidden="true"></i>PDF</button>
        </div>
    </div>

    <ErrorAlert Message="@_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="daily-report-alert success">
            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
            <span>@_success</span>
        </div>
    }

    @if (_loading)
    {
        <div class="daily-report-loading">
            <div class="spinner-border text-success" role="status" aria-label="Cargando reporte diario"></div>
        </div>
    }
    else if (_report is not null)
    {
        <div class="daily-report-kpis">
            <div class="daily-report-kpi kpi-strong"><span>Ventas netas</span><strong>RD$ @_report.NetSales.ToString("N2")</strong><small>Resultado operativo</small></div>
            <div class="daily-report-kpi"><span>Ventas brutas</span><strong>RD$ @_report.GrossSales.ToString("N2")</strong><small>Antes de ajustes</small></div>
            <div class="daily-report-kpi"><span>Gastos</span><strong>RD$ @_report.Expenses.ToString("N2")</strong><small>Registrados hoy</small></div>
            <div class="daily-report-kpi"><span>Efectivo esperado</span><strong>RD$ @_report.ExpectedCash.ToString("N2")</strong><small>Para cierre</small></div>
            <div class="daily-report-kpi"><span>Pollos preparados</span><strong>@_report.PollosPrepared.ToString("N2")</strong><small>Producción</small></div>
            <div class="daily-report-kpi"><span>Pollos vendidos</span><strong>@_report.PollosSoldEquivalent.ToString("N2")</strong><small>Equivalente vendido</small></div>
            <div class="daily-report-kpi"><span>Pollos disponibles</span><strong>@_report.PollosAvailable.ToString("N2")</strong><small>Saldo operativo</small></div>
            <div class="daily-report-kpi warning"><span>Mermas</span><strong>@_report.Waste.ToString("N2")</strong><small>Control de pérdida</small></div>
        </div>

        <div class="row g-3 daily-report-content">
            <div class="col-12 col-xl-5">
                <div class="card border-0 daily-report-panel">
                    <div class="card-header daily-report-panel-header">
                        <div>
                            <strong>Ventas por método de pago</strong>
                            <span>Distribución de cobros del día.</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 daily-report-table compact">
                            <caption>Ventas agrupadas por método de pago y monto</caption>
                            <thead><tr><th>Método</th><th class="text-end">Monto</th></tr></thead>
                            <tbody>
                                @foreach (var item in _report.SalesByPaymentMethod)
                                {
                                    <tr><td data-label="Método">@item.PaymentMethod</td><td class="text-end" data-label="Monto"><strong>RD$ @item.Amount.ToString("N2")</strong></td></tr>
                                }
                                @if (_report.SalesByPaymentMethod.Count == 0)
                                {
                                    <tr><td colspan="2" class="daily-report-empty-cell"><div class="daily-report-empty"><i class="fa-solid fa-circle-info" aria-hidden="true"></i><span>No hay pagos registrados.</span></div></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-7">
                <div class="card border-0 daily-report-panel">
                    <div class="card-header daily-report-panel-header">
                        <div>
                            <strong>Productos más vendidos</strong>
                            <span>Ranking por cantidad, venta y margen.</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 align-middle daily-report-table">
                            <caption>Productos más vendidos con cantidad, monto, costo y margen</caption>
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th class="text-end">Cant.</th>
                                    <th class="text-end">Monto</th>
                                    <th class="text-end">Costo</th>
                                    <th class="text-end">Margen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _report.TopProducts)
                                {
                                    <tr>
                                        <td data-label="Código"><span class="daily-report-code">@item.ProductCode</span></td>
                                        <td data-label="Producto">@item.ProductName</td>
                                        <td class="text-end" data-label="Cant.">@item.Quantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Monto">RD$ @item.SalesAmount.ToString("N2")</td>
                                        <td class="text-end" data-label="Costo">RD$ @item.EstimatedCost.ToString("N2")</td>
                                        <td class="text-end" data-label="Margen">
                                            <strong>RD$ @item.GrossMargin.ToString("N2")</strong>
                                            <div class="small text-muted">@item.GrossMarginPercent.ToString("N2")%</div>
                                        </td>
                                    </tr>
                                }
                                @if (_report.TopProducts.Count == 0)
                                {
                                    <tr><td colspan="6" class="daily-report-empty-cell"><div class="daily-report-empty"><i class="fa-solid fa-circle-info" aria-hidden="true"></i><span>No hay productos vendidos.</span></div></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 daily-report-panel">
                    <div class="card-header daily-report-panel-header">
                        <div>
                            <strong>Ventas del día</strong>
                            <span>Mostrando hasta @SalesRowsLimit ventas.</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0 daily-report-table sales">
                            <caption>Ventas del día con hora, número, estado, total y acciones</caption>
                            <thead>
                                <tr>
                                    <th>Hora</th>
                                    <th>Número</th>
                                    <th>Estado</th>
                                    <th class="text-end">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in _report.Sales)
                                {
                                    <tr>
                                        <td data-label="Hora">@sale.SoldAtUtc.ToLocalTime().ToString("HH:mm")</td>
                                        <td data-label="Número"><span class="daily-report-code">@sale.Number</span></td>
                                        <td data-label="Estado">
                                            <span class="daily-report-status @(sale.Status == "Confirmed" ? "ok" : "danger")">
                                                @GetSaleStatusName(sale.Status)
                                            </span>
                                        </td>
                                        <td class="text-end" data-label="Total"><strong>RD$ @sale.Total.ToString("N2")</strong></td>
                                        <td class="text-end daily-report-row-actions">
                                            <button class="btn btn-sm btn-outline-secondary daily-report-secondary-action" @onclick="() => PrintSale(sale.SaleId)"><i class="fa-solid fa-print" aria-hidden="true"></i>Ticket</button>
                                            @if (sale.Status == "Confirmed")
                                            {
                                                <div class="input-group input-group-sm daily-report-cancel-inline">
                                                    <input class="form-control" placeholder="Motivo de anulación"
                                                           value="@GetCancelReason(sale.SaleId)"
                                                           @oninput="args => SetCancelReason(sale.SaleId, args.Value?.ToString())" />
                                                    <button class="btn btn-outline-danger" @onclick="() => CancelSaleAsync(sale.SaleId)"><i class="fa-solid fa-ban" aria-hidden="true"></i>Anular</button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (_report.Sales.Count == 0)
                                {
                                    <tr><td colspan="5" class="daily-report-empty-cell"><div class="daily-report-empty"><i class="fa-solid fa-circle-info" aria-hidden="true"></i><span>No hay ventas registradas.</span></div></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 daily-report-panel">
                    <div class="card-header daily-report-panel-header">
                        <div>
                            <strong>Inventario bajo mínimo</strong>
                            <span>Alertas operativas para reposición.</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 daily-report-table compact">
                            <caption>Inventario bajo mínimo con código, producto, cantidad actual y mínimo</caption>
                            <thead><tr><th>Código</th><th>Producto</th><th class="text-end">Actual</th><th class="text-end">Minimo</th></tr></thead>
                            <tbody>
                                @foreach (var item in _report.LowStockItems)
                                {
                                    <tr>
                                        <td data-label="Código"><span class="daily-report-code">@item.ProductCode</span></td>
                                        <td data-label="Producto">@item.ProductName</td>
                                        <td class="text-end" data-label="Actual">@item.Quantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Mínimo">@item.Minimum.ToString("N2")</td>
                                    </tr>
                                }
                                @if (_report.LowStockItems.Count == 0)
                                {
                                    <tr><td colspan="4" class="daily-report-empty-cell"><div class="daily-report-empty"><i class="fa-solid fa-circle-check" aria-hidden="true"></i><span>No hay alertas de bajo inventario.</span></div></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;

    private PosContextDto? _context;
    private DailyReportDto? _report;
    private DateTime _selectedDate = DateTime.Today;
    private const int SalesRowsLimit = 100;

    private readonly Dictionary<Guid, string> _cancelReasons = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        _error = null;
        _success = null;

        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _context = contextResult.Value;

        var reportResult = await DailyReportHandler.HandleAsync(new GetDailyReportQuery(
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_selectedDate.Date),
            SalesRowsLimit));

        if (reportResult.IsFailure)
            _error = reportResult.Error.Description;
        else
            _report = reportResult.Value;

        _loading = false;
    }

    private async Task CancelSaleAsync(Guid saleId)
    {
        if (!_cancelReasons.TryGetValue(saleId, out var reason) || string.IsNullOrWhiteSpace(reason))
        {
            _error = "Debe indicar el motivo de anulación.";
            return;
        }

        var result = await CancelSaleHandler.HandleAsync(new CancelSaleCommand(saleId, reason), await GetCurrentUserAsync());
        if (result.IsFailure)
            _error = result.Error.Description;
        else
        {
            _success = "Venta anulada correctamente.";
            await LoadReportAsync();
        }
    }

    private string GetCancelReason(Guid saleId) =>
        _cancelReasons.TryGetValue(saleId, out var reason) ? reason : string.Empty;

    private void SetCancelReason(Guid saleId, string? reason)
    {
        _cancelReasons[saleId] = reason ?? string.Empty;
    }

    private void PrintSale(Guid saleId)
    {
        Navigation.NavigateTo($"/api/receipts/reprint/sale/{saleId}/thermal", forceLoad: true);
    }

    private void Export(string format)
    {
        var date = _selectedDate.ToString("yyyy-MM-dd");
        Navigation.NavigateTo($"/api/reports/daily/{date}/{format}", forceLoad: true);
    }

    private static string GetSaleStatusName(string status) => status switch
    {
        "Confirmed" => "Confirmada",
        "Cancelled" => "Anulada",
        _ => status
    };

    private async Task<string?> GetCurrentUserAsync()
    {
        return await CurrentUser.GetUserNameAsync();
    }
}
