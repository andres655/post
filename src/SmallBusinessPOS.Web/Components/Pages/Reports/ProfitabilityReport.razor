@page "/reports/profitability"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Reports.GetProfitabilityReport

@inject GetPosContextHandler PosContextHandler
@inject GetProfitabilityReportHandler ProfitabilityHandler
@inject NavigationManager Navigation

<PageTitle>Rentabilidad</PageTitle>

<div class="container-fluid report-page profitability-report-page">
    <PageHeader Title="Rentabilidad"
                Subtitle="Margen por rango, producto y dia. Maximo 90 dias."
                IconClass="fa-solid fa-arrow-trend-up"
                HeaderClass="profitability-report-header"
                TitleBlockClass="profitability-report-title-block"
                IconContainerClass="profitability-report-title-icon">
        <Actions>
            <div class="profitability-report-actions">
                <input class="form-control" type="date" @bind="_from" />
                <input class="form-control" type="date" @bind="_to" />
                <button class="btn profitability-report-primary-action" @onclick="LoadReportAsync"><i class="fa-solid fa-magnifying-glass-chart" aria-hidden="true"></i>Consultar</button>
                <button class="btn profitability-report-secondary-action" disabled="@(_report is null)" @onclick='() => Export("csv")'><i class="fa-solid fa-file-csv" aria-hidden="true"></i>CSV</button>
                <button class="btn profitability-report-secondary-action" disabled="@(_report is null)" @onclick='() => Export("pdf")'><i class="fa-solid fa-file-pdf" aria-hidden="true"></i>PDF</button>
            </div>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    @if (_loading)
    {
        <LoadingState Label="Cargando rentabilidad..." ContainerClass="profitability-report-loading" />
    }
    else if (_report is not null)
    {
        <div class="profitability-report-kpis">
            <div class="profitability-report-kpi">
                <span>Ventas netas</span>
                <strong>RD$ @_report.NetSales.ToString("N2")</strong>
            </div>
            <div class="profitability-report-kpi">
                <span>Costo estimado</span>
                <strong>RD$ @_report.EstimatedCost.ToString("N2")</strong>
            </div>
            <div class="profitability-report-kpi">
                <span>Margen bruto</span>
                <strong>RD$ @_report.GrossMargin.ToString("N2")</strong>
                <small>@_report.GrossMarginPercent.ToString("N2")%</small>
            </div>
            <div class="profitability-report-kpi">
                <span>Gastos</span>
                <strong>RD$ @_report.Expenses.ToString("N2")</strong>
            </div>
            <div class="profitability-report-kpi warning">
                <span>Anulaciones</span>
                <strong>RD$ @_report.CancelledAmount.ToString("N2")</strong>
            </div>
            <div class="profitability-report-kpi kpi-strong">
                <span>Utilidad estimada</span>
                <strong>RD$ @_report.NetProfit.ToString("N2")</strong>
            </div>
        </div>

        <div class="row g-3 profitability-report-content">
            <div class="col-12 col-xl-5">
                <div class="card border-0 profitability-report-panel">
                    <div class="profitability-report-panel-header">
                        <div>
                            <strong>Resumen diario</strong>
                            <span>Ventas, costos y utilidad por fecha</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0 align-middle profitability-report-table compact">
                            <caption>Resumen diario de rentabilidad</caption>
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th class="text-end">Ventas</th>
                                    <th class="text-end">Costo</th>
                                    <th class="text-end">Gastos</th>
                                    <th class="text-end">Utilidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var day in _report.Daily)
                                {
                                    <tr>
                                        <td data-label="Fecha">@day.Date.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end" data-label="Ventas">RD$ @day.SalesAmount.ToString("N2")</td>
                                        <td class="text-end" data-label="Costo">RD$ @day.EstimatedCost.ToString("N2")</td>
                                        <td class="text-end" data-label="Gastos">RD$ @day.Expenses.ToString("N2")</td>
                                        <td class="text-end" data-label="Utilidad">
                                            <span class="profitability-report-amount @(day.NetProfit < 0 ? "negative" : "positive")">RD$ @day.NetProfit.ToString("N2")</span>
                                        </td>
                                    </tr>
                                }
                                @if (_report.Daily.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="profitability-report-empty-cell">
                                            <EmptyState Title="No hay datos diarios en el rango."
                                                        IconClass="fa-regular fa-calendar-xmark"
                                                        ContainerClass="profitability-report-empty" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-7">
                <div class="card border-0 profitability-report-panel">
                    <div class="profitability-report-panel-header split">
                        <div>
                            <strong>Rentabilidad por producto</strong>
                            <span>Detalle de margen por artículo vendido</span>
                        </div>
                        <small>Top 100</small>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0 profitability-report-table">
                            <caption>Rentabilidad por producto</caption>
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th class="text-end">Cant.</th>
                                    <th class="text-end">Ventas</th>
                                    <th class="text-end">Costo</th>
                                    <th class="text-end">Margen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in _report.Products)
                                {
                                    <tr>
                                        <td data-label="Código"><span class="profitability-report-code">@product.ProductCode</span></td>
                                        <td data-label="Producto">@product.ProductName</td>
                                        <td class="text-end" data-label="Cant.">@product.Quantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Ventas">RD$ @product.SalesAmount.ToString("N2")</td>
                                        <td class="text-end" data-label="Costo">RD$ @product.EstimatedCost.ToString("N2")</td>
                                        <td class="text-end" data-label="Margen">
                                            <span class="profitability-report-margin @(product.GrossMargin < 0 ? "negative" : "positive")">
                                                RD$ @product.GrossMargin.ToString("N2")
                                            </span>
                                            <div class="profitability-report-margin-rate">@product.GrossMarginPercent.ToString("N2")%</div>
                                        </td>
                                    </tr>
                                }
                                @if (_report.Products.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="profitability-report-empty-cell">
                                            <EmptyState Title="No hay ventas confirmadas en el rango."
                                                        IconClass="fa-solid fa-chart-line"
                                                        ContainerClass="profitability-report-empty" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private PosContextDto? _context;
    private ProfitabilityReportDto? _report;
    private DateTime _from = DateTime.Today.AddDays(-7);
    private DateTime _to = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        _error = null;

        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _context = contextResult.Value;

        var result = await ProfitabilityHandler.HandleAsync(new GetProfitabilityReportQuery(
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_from.Date),
            DateOnly.FromDateTime(_to.Date)));

        if (result.IsFailure)
            _error = result.Error.Description;
        else
            _report = result.Value;

        _loading = false;
    }

    private void Export(string format)
    {
        var from = _from.ToString("yyyy-MM-dd");
        var to = _to.ToString("yyyy-MM-dd");
        Navigation.NavigateTo($"/api/reports/profitability/{from}/{to}/{format}", forceLoad: true);
    }
}
