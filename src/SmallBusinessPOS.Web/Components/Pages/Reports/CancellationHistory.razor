@page "/sales/cancellations"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Sales.GetCancellationHistory
@using SmallBusinessPOS.Application.Features.Sales.GetSaleByNumber

@inject GetPosContextHandler PosContextHandler
@inject GetCancellationHistoryHandler HistoryHandler
@inject GetSaleByNumberHandler LookupHandler
@inject NavigationManager Navigation

<PageTitle>Historial de anulaciones</PageTitle>

<div class="container-fluid cancellation-history-page">
    <div class="cancellation-history-header">
        <div class="cancellation-history-title-block">
            <span class="cancellation-history-title-icon" aria-hidden="true">
                <i class="fa-solid fa-ban"></i>
            </span>
            <div>
                <h2>Historial de anulaciones</h2>
                <span>Audita ventas anuladas y reimpresiones autorizadas.</span>
            </div>
        </div>
        <span class="cancellation-history-role-badge">
            <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
            Solo Supervisor / Administrator
        </span>
    </div>

    <div class="card border-0 cancellation-history-filter-card">
        <div class="card-body cancellation-history-filter-body">
            <div class="cancellation-history-section-label">
                <strong>Rango de auditoría</strong>
                <span>Consulta anulaciones por fecha.</span>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label mb-1">Desde</label>
                    <input type="date" class="form-control" @bind="_fromDate" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label mb-1">Hasta</label>
                    <input type="date" class="form-control" @bind="_toDate" />
                </div>
                <div class="col-12 col-md-2">
                    <button class="btn btn-primary w-100 cancellation-history-primary-action" @onclick="LoadAsync"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>Buscar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 cancellation-history-filter-card">
        <div class="card-body cancellation-history-filter-body">
            <div class="cancellation-history-section-label">
                <strong>Reimpresión autorizada</strong>
                <span>Busca una venta específica por número.</span>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-6">
                    <label class="form-label mb-1">Reimprimir por número de venta</label>
                    <input class="form-control" placeholder="Ej: PRIN-C01-20260716-000025" @bind="_saleNumber" />
                </div>
                <div class="col-12 col-md-2">
                    <button class="btn btn-outline-secondary w-100 cancellation-history-secondary-action" @onclick="ReprintByNumberAsync"><i class="fa-solid fa-print" aria-hidden="true"></i>Reimprimir</button>
                </div>
            </div>
        </div>
    </div>

    <ErrorAlert Message="@_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="cancellation-history-alert success">
            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
            <span>@_success</span>
        </div>
    }

    @if (_loading)
    {
        <div class="cancellation-history-loading">
            <div class="spinner-border text-success" role="status" aria-label="Cargando historial de anulaciones"></div>
        </div>
    }
    else
    {
        <div class="card border-0 cancellation-history-table-card">
            <div class="card-header cancellation-history-table-header">
                <div>
                    <strong>Ventas anuladas</strong>
                    <small>Resultados del rango seleccionado.</small>
                </div>
                <span>@_rows.Count resultados</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 cancellation-history-table">
                    <caption>Historial de ventas anuladas con número, fechas, usuario, motivo, total y reimpresión</caption>
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Fecha venta</th>
                            <th>Fecha anulación</th>
                            <th>Usuario</th>
                            <th>Motivo</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td data-label="Número"><span class="cancellation-history-number">@row.Number</span></td>
                                <td data-label="Fecha venta">@row.SoldAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td data-label="Fecha anulación">@row.CancelledAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td data-label="Usuario">@(row.CancelledBy ?? "-")</td>
                                <td data-label="Motivo">@row.Reason</td>
                                <td class="text-end" data-label="Total"><strong>RD$ @row.Total.ToString("N2")</strong></td>
                                <td class="text-end cancellation-history-row-action">
                                    <button class="btn btn-sm btn-outline-secondary cancellation-history-secondary-action" @onclick="() => ReprintNumber(row.Number)">
                                        <i class="fa-solid fa-print" aria-hidden="true"></i>
                                        Reimprimir
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (_rows.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="cancellation-history-empty-cell">
                                    <div class="cancellation-history-empty">
                                        <span class="cancellation-history-empty-icon" aria-hidden="true">
                                            <i class="fa-solid fa-circle-check"></i>
                                        </span>
                                        <div>
                                            <strong>No hay anulaciones en el rango seleccionado.</strong>
                                            <small>Ajusta las fechas si necesitas ampliar la búsqueda.</small>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;

    private DateTime _fromDate = DateTime.Today.AddDays(-7);
    private DateTime _toDate = DateTime.Today;

    private string _saleNumber = string.Empty;
    private PosContextDto? _context;
    private List<CancelledSaleDto> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _success = null;

        var context = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (context.IsFailure)
        {
            _error = context.Error.Description;
            _loading = false;
            return;
        }

        _context = context.Value;

        var result = await HistoryHandler.HandleAsync(new GetCancellationHistoryQuery(
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_fromDate.Date),
            DateOnly.FromDateTime(_toDate.Date)));

        if (result.IsFailure)
            _error = result.Error.Description;
        else
            _rows = result.Value;

        _loading = false;
    }

    private async Task ReprintByNumberAsync()
    {
        if (_context is null)
            return;

        var lookup = await LookupHandler.HandleAsync(new GetSaleByNumberQuery(_context.BusinessId, _saleNumber));
        if (lookup.IsFailure)
        {
            _error = lookup.Error.Description;
            return;
        }

        Navigation.NavigateTo($"/api/receipts/reprint/by-number/{Uri.EscapeDataString(lookup.Value.Number)}/thermal", forceLoad: true);
        _success = $"Reimpresión enviada para {lookup.Value.Number}.";
    }

    private void ReprintNumber(string number)
    {
        Navigation.NavigateTo($"/api/receipts/reprint/by-number/{Uri.EscapeDataString(number)}/thermal", forceLoad: true);
    }
}
