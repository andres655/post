@page "/audit"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Reports.GetOperationalAudit

@inject GetPosContextHandler PosContextHandler
@inject GetOperationalAuditHandler AuditHandler

<PageTitle>Auditoría operacional</PageTitle>

<div class="container-fluid audit-page operational-audit-page">
    <div class="operational-audit-header">
        <div class="operational-audit-title-block">
            <span class="operational-audit-title-icon" aria-hidden="true">
                <i class="fa-solid fa-shield-halved"></i>
            </span>
            <div>
                <h2>Auditoría operativa</h2>
                <span>Usuario, fecha, entidad afectada, acción y detalle de cada movimiento.</span>
            </div>
        </div>
        <button class="btn btn-dark operational-audit-primary-action" @onclick="LoadAuditAsync">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>Consultar
        </button>
    </div>

    <ErrorAlert Message="@_error" />

    <div class="card border-0 operational-audit-filter-card">
        <div class="card-body operational-audit-filter-body">
            <div class="operational-audit-section-label">
                <strong>Filtros de auditoría</strong>
                <span>Acota los movimientos por fecha, usuario y área.</span>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" @bind="_from" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" @bind="_to" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Usuario</label>
                    <InputText class="form-control" @bind-Value="_user" placeholder="email o nombre" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Area</label>
                    <select class="form-select" @bind="_area">
                        <option value="">Todas</option>
                        <option value="Ventas">Ventas</option>
                        <option value="Caja">Caja</option>
                        <option value="Inventario">Inventario</option>
                        <option value="Gastos">Gastos</option>
                        <option value="Produccion">Producción</option>
                        <option value="Tickets">Tickets</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (!_loading)
    {
        <div class="operational-audit-kpis">
            <div class="operational-audit-kpi kpi-strong"><span>Movimientos</span><strong>@_entries.Count</strong><small>Eventos auditados</small></div>
            <div class="operational-audit-kpi"><span>Usuarios</span><strong>@_entries.Select(e => e.User).Distinct(StringComparer.OrdinalIgnoreCase).Count()</strong><small>Con actividad</small></div>
            <div class="operational-audit-kpi"><span>Áreas</span><strong>@_entries.Select(e => e.Area).Distinct().Count()</strong><small>Módulos afectados</small></div>
            <div class="operational-audit-kpi"><span>Último evento</span><strong>@(_entries.Count == 0 ? "-" : _entries.Max(e => e.OccurredAtUtc).ToLocalTime().ToString("dd/MM HH:mm"))</strong><small>Fecha local</small></div>
        </div>
    }

    @if (_loading)
    {
        <div class="operational-audit-loading">
            <div class="spinner-border text-success" role="status" aria-label="Cargando auditoría operacional"></div>
        </div>
    }
    else
    {
        <div class="card border-0 operational-audit-table-card">
            <div class="card-header operational-audit-table-header">
                <div>
                    <strong>Movimientos auditados</strong>
                    <small>@AuditCountText</small>
                </div>
                <span>@_entries.Count eventos</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 operational-audit-table">
                    <caption>Auditoría operacional con fecha, usuario, área, acción, entidad afectada, monto o cantidad y detalle</caption>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Usuario</th>
                            <th>Area</th>
                            <th>Accion</th>
                            <th>Entidad afectada</th>
                            <th class="text-end">Monto/Cant.</th>
                            <th>Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in PagedEntries)
                        {
                            <tr>
                                <td data-label="Fecha">@entry.OccurredAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="audit-user" data-label="Usuario">@entry.User</td>
                                <td data-label="Área"><span class="operational-audit-area">@entry.Area</span></td>
                                <td data-label="Acción"><span class="operational-audit-action">@entry.Action</span></td>
                                <td data-label="Entidad">
                                    <div class="fw-semibold">@entry.Reference</div>
                                    <small class="text-muted">@entry.EntityType / @entry.EntityId</small>
                                </td>
                                <td class="text-end" data-label="Monto/Cant.">@(entry.Amount?.ToString("N2") ?? "-")</td>
                                <td data-label="Detalle">@entry.Details</td>
                            </tr>
                        }
                        @if (_entries.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="operational-audit-empty-cell">
                                    <div class="operational-audit-empty">
                                        <span class="operational-audit-empty-icon" aria-hidden="true">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </span>
                                        <div>
                                            <strong>No hay movimientos para los filtros seleccionados.</strong>
                                            <small>Ajusta el rango, usuario o área para ampliar la búsqueda.</small>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_entries.Count > 0)
            {
                <div class="operational-audit-table-footer">
                    <span>@AuditCountText</span>
                    <TablePager CurrentPage="_page" TotalPages="TotalPages" CurrentPageChanged="SetPage" />
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private PosContextDto? _context;
    private DateTime _from = DateTime.Today.AddDays(-7);
    private DateTime _to = DateTime.Today;
    private string? _user;
    private string _area = string.Empty;
    private IReadOnlyList<OperationalAuditEntryDto> _entries = [];
    private const int TablePageSize = 5;
    private int _page = 1;
    private IEnumerable<OperationalAuditEntryDto> PagedEntries =>
        _entries.Skip((_page - 1) * TablePageSize).Take(TablePageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_entries.Count / (double)TablePageSize));
    private string AuditCountText
    {
        get
        {
            if (_entries.Count == 0)
                return "0 eventos";

            var start = ((_page - 1) * TablePageSize) + 1;
            var end = Math.Min(_page * TablePageSize, _entries.Count);
            return $"Mostrando {start:N0}-{end:N0} de {_entries.Count:N0}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAuditAsync();
    }

    private async Task LoadAuditAsync()
    {
        _loading = true;
        _error = null;

        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _context = contextResult.Value;
        var result = await AuditHandler.HandleAsync(new GetOperationalAuditQuery(
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_from.Date),
            DateOnly.FromDateTime(_to.Date),
            string.IsNullOrWhiteSpace(_user) ? null : _user,
            string.IsNullOrWhiteSpace(_area) ? null : _area));

        if (result.IsFailure)
            _error = result.Error.Description;
        else
        {
            _entries = result.Value;
            _page = 1;
        }

        _loading = false;
    }

    private void SetPage(int page) => _page = Math.Clamp(page, 1, TotalPages);
}
