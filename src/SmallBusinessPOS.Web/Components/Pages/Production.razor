@page "/production"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Production.ConfirmProductionEntry
@using SmallBusinessPOS.Application.Features.Production.GetProductionProducts
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject GetProductionProductsHandler GetProductionProductsHandler
@inject ConfirmProductionEntryHandler ConfirmProductionEntryHandler
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Producción</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Producción diaria</h2>
        <span class="badge bg-info-subtle text-info">Supervisor / Administrator</span>
    </div>

    <ErrorAlert Message="_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    <div class="row g-3">
        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white"><strong>Confirmar producción</strong></div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Fecha</label>
                        <input class="form-control" type="date" @bind="_productionDate" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Producto</label>
                        <select class="form-select" @bind="_selectedProductId">
                            <option value="@Guid.Empty">Seleccione...</option>
                            @foreach (var product in _products)
                            {
                                <option value="@product.ProductId">@product.Code - @product.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Cantidad producida</label>
                        <InputNumber class="form-control" @bind-Value="_quantityProduced" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Merma</label>
                        <InputNumber class="form-control" @bind-Value="_quantityWasted" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Costo unitario</label>
                        <InputNumber class="form-control" @bind-Value="_unitCost" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notas</label>
                        <textarea class="form-control" rows="3" @bind="_notes"></textarea>
                    </div>
                    <button class="btn btn-primary w-100" disabled="@_saving" @onclick="ConfirmAsync">
                        @(_saving ? "Confirmando..." : "Confirmar producción")
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white"><strong>Productos preparados disponibles</strong></div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Producto</th>
                                <th class="text-end">Costo estimado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in _products)
                            {
                                <tr>
                                    <td>@product.Code</td>
                                    <td>@product.Name</td>
                                    <td class="text-end">RD$ @product.EstimatedCost.ToString("N2")</td>
                                </tr>
                            }
                            @if (_products.Count == 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4">No hay productos preparados con control de inventario.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PosContextDto? _context;
    private List<ProductionProductDto> _products = [];
    private string? _error;
    private string? _success;
    private bool _saving;

    private DateTime _productionDate = DateTime.Today;
    private Guid _selectedProductId = Guid.Empty;
    private decimal _quantityProduced;
    private decimal _quantityWasted;
    private decimal _unitCost;
    private string? _notes;

    protected override async Task OnInitializedAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            return;
        }

        _context = contextResult.Value;

        var productsResult = await GetProductionProductsHandler.HandleAsync(
            new GetProductionProductsQuery(_context.BusinessId));

        if (productsResult.IsFailure)
        {
            _error = productsResult.Error.Description;
            return;
        }

        _products = productsResult.Value;
        if (_products.Count > 0)
        {
            _selectedProductId = _products[0].ProductId;
            _unitCost = _products[0].EstimatedCost;
        }
    }

    private async Task ConfirmAsync()
    {
        _saving = true;
        _error = null;
        _success = null;

        if (_context is null)
        {
            _error = "No hay contexto operativo disponible.";
            _saving = false;
            return;
        }

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var result = await ConfirmProductionEntryHandler.HandleAsync(new ConfirmProductionEntryCommand(
            ProductionEntryId: null,
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_productionDate.Date),
            [new ConfirmProductionEntryLine(_selectedProductId, _quantityProduced, _unitCost, _quantityWasted)],
            _notes), currentUser);

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            _saving = false;
            return;
        }

        _success = $"Producción {result.Value.Number} confirmada. Producido: {result.Value.TotalQuantityProduced:N2}. Merma: {result.Value.TotalQuantityWasted:N2}. Agregado neto: {result.Value.NetQuantityAdded:N2}.";
        _quantityProduced = 0m;
        _quantityWasted = 0m;
        _notes = null;
        _saving = false;
    }
}
