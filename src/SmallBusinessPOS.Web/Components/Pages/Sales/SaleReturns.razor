@page "/sales/returns"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Interfaces
@using SmallBusinessPOS.Application.Features.PaymentMethods.GetActivePaymentMethods
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Sales.GetSaleForReturn
@using SmallBusinessPOS.Application.Features.Sales.RegisterSaleReturn

@inject GetPosContextHandler PosContextHandler
@inject GetActivePaymentMethodsHandler PaymentMethodsHandler
@inject GetSaleForReturnHandler GetSaleForReturnHandler
@inject RegisterSaleReturnHandler RegisterReturnHandler
@inject ICurrentUserService CurrentUser

<PageTitle>Devoluciones - CajaPyme</PageTitle>

<div class="container-fluid sales-return-page">
    <PageHeader Title="Devoluciones parciales"
                Subtitle="Busca una venta, selecciona cantidades y registra el reembolso."
                IconClass="fa-solid fa-rotate-left"
                HeaderClass="sales-return-header"
                TitleBlockClass="sales-return-title-block"
                IconContainerClass="sales-return-title-icon">
        <Actions>
        <div class="sales-return-context">
            @if (_context is not null)
            {
                <span>@_context.BusinessName</span>
                <strong>@_context.BranchName</strong>
            }
        </div>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <SuccessAlert Message="@_success" CssClass="sales-return-alert success" Dismissible="false" />
    }

    <div class="card border-0 sales-return-search-panel">
        <div class="card-body">
            <div class="sales-return-search-copy">
                <strong>Buscar venta original</strong>
                <span>Ingresa el número del comprobante para validar los productos disponibles.</span>
            </div>
            <label class="form-label" for="sale-return-number">Número de venta</label>
            <div class="sales-return-search-control">
                <input id="sale-return-number" class="form-control" @bind="_saleNumber" placeholder="PRIN-C01-20260718-000001" />
                <SaveButton CssClass="btn sales-return-primary-action"
                            Text="Buscar"
                            IconClass="fa-solid fa-magnifying-glass"
                            OnClick="SearchSaleAsync" />
            </div>
        </div>
    </div>

    @if (_sale is not null)
    {
        <div class="sales-return-workspace">
            <div class="sales-return-main">
                <div class="card border-0 sales-return-panel">
                    <div class="sales-return-sale-summary">
                        <div>
                            <span>Venta encontrada</span>
                            <strong>@_sale.Number</strong>
                        </div>
                        <div>
                            <span>Cliente</span>
                            <strong>@_sale.CustomerName</strong>
                        </div>
                        <div>
                            <span>Total original</span>
                            <strong>RD$ @_sale.Total.ToString("N2")</strong>
                        </div>
                    </div>
                    <div class="sales-return-panel-header">
                        <div>
                            <strong>Productos de la venta</strong>
                            <span>Indica la cantidad exacta a devolver por línea.</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0 sales-return-table">
                            <caption>Productos disponibles para devolución</caption>
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Vendido</th>
                                    <th class="text-end">Devuelto</th>
                                    <th class="text-end">Disponible</th>
                                    <th class="text-end">A devolver</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in _sale.Lines)
                                {
                                    <tr>
                                        <td data-label="Producto">
                                            <span class="sales-return-code">@line.ProductCode</span>
                                            <div class="sales-return-product-name">@line.ProductName</div>
                                        </td>
                                        <td class="text-end" data-label="Vendido">@line.SoldQuantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Devuelto">@line.ReturnedQuantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Disponible">
                                            <span class="sales-return-available">@line.AvailableQuantity.ToString("N2")</span>
                                        </td>
                                        <td class="text-end" data-label="A devolver">
                                            <input class="form-control text-end sales-return-quantity-input"
                                                   type="number"
                                                   min="0"
                                                   max="@line.AvailableQuantity"
                                                   step="0.01"
                                                   value="@GetReturnQuantity(line.SaleDetailId)"
                                                   @onchange="args => SetReturnQuantity(line.SaleDetailId, args.Value)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <aside class="sales-return-side">
                <div class="card border-0 sales-return-panel sales-return-refund-panel">
                    <div class="sales-return-panel-header">
                        <div>
                            <strong>Reembolso</strong>
                            <span>Completa los datos antes de registrar.</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="sales-return-total-card">
                            <span>Total a devolver</span>
                            <strong>RD$ @ReturnTotal.ToString("N2")</strong>
                        </div>

                        <div class="sales-return-form-grid">
                            <div>
                                <label class="form-label">Método de reembolso</label>
                                <select class="form-select" @bind="_refundPaymentMethodId">
                                    @foreach (var payment in _paymentMethods)
                                    {
                                        <option value="@payment.Id.ToString()">@payment.Name</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Referencia</label>
                                <input class="form-control" @bind="_refundReference" placeholder="Obligatoria si no es efectivo" />
                            </div>
                            <div>
                                <label class="form-label">Motivo</label>
                                <input class="form-control" @bind="_reason" />
                            </div>
                        </div>

                        <SaveButton CssClass="btn sales-return-danger-action"
                                    Text="Registrar devolución"
                                    Disabled="@(ReturnTotal <= 0)"
                                    IconClass="fa-solid fa-rotate-left"
                                    OnClick="RegisterReturnAsync" />
                    </div>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    private PosContextDto? _context;
    private string _saleNumber = string.Empty;
    private SaleForReturnDto? _sale;
    private List<PaymentMethodDto> _paymentMethods = [];
    private readonly Dictionary<Guid, decimal> _returnQuantities = [];
    private string? _refundPaymentMethodId;
    private string? _refundReference;
    private string _reason = "Devolucion de cliente";
    private string? _error;
    private string? _success;

    private decimal ReturnTotal => _sale is null
        ? 0m
        : _sale.Lines.Sum(line => GetReturnQuantity(line.SaleDetailId) * line.UnitPrice);

    protected override async Task OnInitializedAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            return;
        }

        _context = contextResult.Value;
        var methodsResult = await PaymentMethodsHandler.HandleAsync(new GetActivePaymentMethodsQuery(_context.BusinessId));
        if (methodsResult.IsSuccess)
        {
            _paymentMethods = methodsResult.Value;
            _refundPaymentMethodId = _paymentMethods.FirstOrDefault()?.Id.ToString();
        }
    }

    private async Task SearchSaleAsync()
    {
        if (_context is null)
            return;

        _error = null;
        _success = null;
        _returnQuantities.Clear();

        var result = await GetSaleForReturnHandler.HandleAsync(new GetSaleForReturnQuery(_context.BusinessId, _saleNumber));
        if (result.IsFailure)
        {
            _sale = null;
            _error = result.Error.Description;
            return;
        }

        _sale = result.Value;
    }

    private decimal GetReturnQuantity(Guid saleDetailId) =>
        _returnQuantities.TryGetValue(saleDetailId, out var value) ? value : 0m;

    private void SetReturnQuantity(Guid saleDetailId, object? value)
    {
        if (!decimal.TryParse(Convert.ToString(value), out var quantity) || quantity <= 0)
            _returnQuantities.Remove(saleDetailId);
        else
            _returnQuantities[saleDetailId] = quantity;
    }

    private async Task RegisterReturnAsync()
    {
        if (_sale is null || !Guid.TryParse(_refundPaymentMethodId, out var refundMethodId))
            return;

        var lines = _returnQuantities
            .Where(item => item.Value > 0)
            .Select(item => new RegisterSaleReturnLine(item.Key, item.Value))
            .ToList();

        var result = await RegisterReturnHandler.HandleAsync(new RegisterSaleReturnCommand(
            _sale.SaleId,
            refundMethodId,
            _reason,
            lines,
            _refundReference), await GetCurrentUserAsync());

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            return;
        }

        _success = "Devolucion registrada correctamente.";
        await SearchSaleAsync();
    }

    private async Task<string?> GetCurrentUserAsync()
    {
        return await CurrentUser.GetUserNameAsync();
    }
}
