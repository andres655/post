@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Configuración - CajaPyme</PageTitle>

<div class="container-fluid settings-page">
    <PageHeader Title="Configuración"
                HeaderClass="settings-header"
                TitleClass="mb-0">
        <SubtitleContent>
            @if (_context is not null)
            {
                <div class="text-muted small">@_context.BusinessName / @_context.BranchName</div>
            }
        </SubtitleContent>
        <Actions>
            <SaveButton CssClass="btn btn-primary settings-save-button"
                        Text="Guardar"
                        SavingText="Guardando"
                        IconClass="fa-solid fa-floppy-disk me-1"
                        Saving="@_saving"
                        Disabled="@(_loading || _saving)"
                        OnClick="SaveAsync" />
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />
    <SuccessAlert Message="@_success"
                  CssClass="alert alert-success alert-dismissible settings-alert success"
                  OnClose="@(() => _success = null)" />

    @if (_loading)
    {
        <LoadingState ContainerClass="text-center py-5 settings-loading"
                      SpinnerClass="spinner-border text-primary" />
    }
    else
    {
        <div class="row g-3 settings-grid">
            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm settings-card">
                    <div class="card-header bg-white settings-card-header">
                        <span class="settings-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-store"></i>
                        </span>
                        <div>
                            <strong>Negocio</strong>
                            <small>Datos comerciales y fiscales</small>
                        </div>
                    </div>
                    <div class="card-body settings-card-body settings-form-grid">
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="businessName">Nombre del negocio</label>
                            <input class="form-control" id="businessName" maxlength="200" @bind="_form.BusinessName" />
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="taxId">RNC / identificación fiscal</label>
                            <input class="form-control" id="taxId" maxlength="50" @bind="_form.TaxId" />
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="businessPhone">Teléfono</label>
                            <input class="form-control" id="businessPhone" maxlength="30" @bind="_form.BusinessPhone" />
                        </div>
                        <div class="mb-0 settings-field settings-field-full">
                            <label class="form-label" for="businessAddress">Dirección del negocio</label>
                            <textarea class="form-control" id="businessAddress" rows="3" maxlength="500" @bind="_form.BusinessAddress"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm settings-card">
                    <div class="card-header bg-white settings-card-header">
                        <span class="settings-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-receipt"></i>
                        </span>
                        <div>
                            <strong>Sucursal y ticket</strong>
                            <small>Identidad impresa en recibos</small>
                        </div>
                    </div>
                    <div class="card-body settings-card-body settings-form-grid">
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="branchName">Nombre de sucursal</label>
                            <input class="form-control" id="branchName" maxlength="120" @bind="_form.BranchName" />
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="branchPhone">Teléfono de sucursal</label>
                            <input class="form-control" id="branchPhone" maxlength="30" @bind="_form.BranchPhone" />
                        </div>
                        <div class="mb-3 settings-field settings-field-full">
                            <label class="form-label" for="branchAddress">Dirección en ticket</label>
                            <textarea class="form-control" id="branchAddress" rows="3" maxlength="500" @bind="_form.BranchAddress"></textarea>
                        </div>
                        <div class="mb-3 settings-field settings-field-full">
                            <label class="form-label" for="receiptLogoFile">Logo del ticket</label>
                            <InputFile id="receiptLogoFile" class="form-control" accept="image/png,image/jpeg,image/webp" OnChange="OnLogoSelectedAsync" />
                            @if (!string.IsNullOrWhiteSpace(_form.ReceiptLogoPath))
                            {
                                <div class="receipt-logo-preview mt-2 settings-logo-preview">
                                    <img src="@LogoPreviewUrl" alt="Logo del ticket" />
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="RemoveLogo">
                                        <i class="fa-solid fa-trash-can me-1"></i>Quitar
                                    </button>
                                </div>
                            }
                        </div>
                        <div class="mb-0 settings-field settings-field-full">
                            <label class="form-label" for="receiptHeader">Encabezado extra</label>
                            <textarea class="form-control" id="receiptHeader" rows="3" maxlength="500" @bind="_form.ReceiptHeader"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm settings-card">
                    <div class="card-header bg-white settings-card-header">
                        <span class="settings-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-cart-shopping"></i>
                        </span>
                        <div>
                            <strong>Ventas e inventario</strong>
                            <small>Reglas operativas y moneda</small>
                        </div>
                    </div>
                    <div class="card-body settings-card-body settings-switch-list">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="usesTaxes" @bind="_form.UsesTaxes" />
                            <label class="form-check-label" for="usesTaxes">Impuestos</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="allowsCredit" @bind="_form.AllowsCredit" />
                            <label class="form-check-label" for="allowsCredit">Crédito</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="allowsNegativeInventory" @bind="_form.AllowsNegativeInventory" />
                            <label class="form-check-label" for="allowsNegativeInventory">Permitir inventario negativo</label>
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="currencySymbol">Símbolo de moneda</label>
                            <input class="form-control" id="currencySymbol" maxlength="10" @bind="_form.CurrencySymbol" />
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="currencyCode">Código de moneda</label>
                            <input class="form-control" id="currencyCode" maxlength="10" @bind="_form.CurrencyCode" />
                        </div>
                        <div class="mb-3 settings-field">
                            <label class="form-label" for="defaultTaxRate">Impuesto por defecto (%)</label>
                            <input class="form-control" id="defaultTaxRate" type="number" min="0" max="100" step="0.01" @bind="_form.DefaultTaxRate" />
                        </div>
                        <div class="mb-0 settings-field">
                            <label class="form-label" for="ticketFooter">Pie del ticket</label>
                            <textarea class="form-control" id="ticketFooter" rows="4" maxlength="500" @bind="_form.TicketFooter"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm settings-card settings-card-compact">
                    <div class="card-header bg-white settings-card-header">
                        <span class="settings-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-layer-group"></i>
                        </span>
                        <div>
                            <strong>Módulos</strong>
                            <small>Capacidades activas del sistema</small>
                        </div>
                    </div>
                    <div class="card-body settings-card-body settings-switch-list">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="usesInventory" @bind="_form.UsesInventory" />
                            <label class="form-check-label" for="usesInventory">Inventario</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="usesProduction" @bind="_form.UsesProduction" />
                            <label class="form-check-label" for="usesProduction">Producción</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="usesKitchen" @bind="_form.UsesKitchen" />
                            <label class="form-check-label" for="usesKitchen">Cocina</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="usesDelivery" @bind="_form.UsesDelivery" />
                            <label class="form-check-label" for="usesDelivery">Delivery</label>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="usesCustomers" @bind="_form.UsesCustomers" />
                            <label class="form-check-label" for="usesCustomers">Clientes</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

