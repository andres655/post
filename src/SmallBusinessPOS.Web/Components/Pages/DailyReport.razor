@page "/reports/daily"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Sales.CancelSale
@using SmallBusinessPOS.Application.Features.Sales.GetDailyReport

@inject GetPosContextHandler PosContextHandler
@inject GetDailyReportHandler DailyReportHandler
@inject CancelSaleHandler CancelSaleHandler
@inject NavigationManager Navigation

<PageTitle>Reporte diario</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Reporte diario</h2>
        <div class="d-flex gap-2 align-items-center">
            <input class="form-control" style="width:170px" type="date" @bind="_selectedDate" />
            <button class="btn btn-primary" @onclick="LoadReportAsync">Actualizar</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (_report is not null)
    {
        <div class="row g-3 mb-3">
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Ventas brutas</small><div class="fs-5 fw-bold">RD$ @_report.GrossSales.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Descuentos</small><div class="fs-5 fw-bold">RD$ @_report.Discounts.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Anulaciones</small><div class="fs-5 fw-bold">RD$ @_report.CancelledAmount.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Ventas netas</small><div class="fs-5 fw-bold">RD$ @_report.NetSales.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Gastos</small><div class="fs-5 fw-bold">RD$ @_report.Expenses.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Ventas</small><div class="fs-5 fw-bold">@_report.SalesCount</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Efectivo esperado</small><div class="fs-5 fw-bold">RD$ @_report.ExpectedCash.ToString("N2")</div></div></div></div>
            <div class="col-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><small class="text-muted">Pollos disponibles</small><div class="fs-5 fw-bold">@_report.PollosAvailable.ToString("N2")</div></div></div></div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><strong>Ventas por método de pago</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Método</th><th class="text-end">Monto</th></tr></thead>
                            <tbody>
                            @foreach (var item in _report.SalesByPaymentMethod)
                            {
                                <tr><td>@item.PaymentMethod</td><td class="text-end">RD$ @item.Amount.ToString("N2")</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><strong>Productos más vendidos</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Código</th><th>Producto</th><th class="text-end">Cant.</th><th class="text-end">Monto</th></tr></thead>
                            <tbody>
                            @foreach (var item in _report.TopProducts)
                            {
                                <tr>
                                    <td>@item.ProductCode</td>
                                    <td>@item.ProductName</td>
                                    <td class="text-end">@item.Quantity.ToString("N2")</td>
                                    <td class="text-end">RD$ @item.SalesAmount.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><strong>Ventas del día</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Hora</th><th>Número</th><th>Estado</th><th class="text-end">Total</th><th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in _report.Sales)
                                {
                                    <tr>
                                        <td>@sale.SoldAtUtc.ToLocalTime().ToString("HH:mm")</td>
                                        <td>@sale.Number</td>
                                        <td>
                                            <span class="badge @(sale.Status == "Confirmed" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                                @sale.Status
                                            </span>
                                        </td>
                                        <td class="text-end">RD$ @sale.Total.ToString("N2")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => PrintSale(sale.SaleId)">Ticket</button>
                                            @if (sale.Status == "Confirmed")
                                            {
                                                <div class="input-group input-group-sm mt-1" style="max-width:360px; margin-left:auto;">
                                                    <input class="form-control" placeholder="Motivo de anulación"
                                                           @bind="_cancelReasons[sale.SaleId]" />
                                                    <button class="btn btn-outline-danger" @onclick="() => CancelSaleAsync(sale.SaleId)">Anular</button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><strong>Inventario bajo mínimo</strong></div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Código</th><th>Producto</th><th class="text-end">Actual</th><th class="text-end">Mínimo</th></tr></thead>
                            <tbody>
                                @foreach (var i in _report.LowStockItems)
                                {
                                    <tr>
                                        <td>@i.ProductCode</td>
                                        <td>@i.ProductName</td>
                                        <td class="text-end">@i.Quantity.ToString("N2")</td>
                                        <td class="text-end">@i.Minimum.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private string? _success;

    private PosContextDto? _context;
    private DailyReportDto? _report;
    private DateTime _selectedDate = DateTime.Today;

    private readonly Dictionary<Guid, string> _cancelReasons = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        _loading = true;
        _error = null;
        _success = null;

        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _context = contextResult.Value;

        var date = DateOnly.FromDateTime(_selectedDate.Date);

        var reportResult = await DailyReportHandler.HandleAsync(new GetDailyReportQuery(
            _context.BusinessId,
            _context.BranchId,
            date));

        if (reportResult.IsFailure)
            _error = reportResult.Error.Description;
        else
            _report = reportResult.Value;

        _loading = false;
    }

    private async Task CancelSaleAsync(Guid saleId)
    {
        if (!_cancelReasons.TryGetValue(saleId, out var reason) || string.IsNullOrWhiteSpace(reason))
        {
            _error = "Debe indicar el motivo de anulación.";
            return;
        }

        var result = await CancelSaleHandler.HandleAsync(new CancelSaleCommand(saleId, reason));
        if (result.IsFailure)
            _error = result.Error.Description;
        else
        {
            _success = "Venta anulada correctamente.";
            await LoadReportAsync();
        }
    }

    private void PrintSale(Guid saleId)
    {
        Navigation.NavigateTo($"/api/receipts/sale/{saleId}", forceLoad: true);
    }
}
