@page "/cash/history"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.CashSessions.GetCashSessionHistory
@using SmallBusinessPOS.Application.Features.CashSessions.GetCashSessionSummary
@using SmallBusinessPOS.Application.Features.POS.GetPosContext

@inject GetPosContextHandler PosContextHandler
@inject GetCashSessionHistoryHandler HistoryHandler
@inject NavigationManager Navigation

<PageTitle>Historial de caja</PageTitle>

<div class="container-fluid cash-history-page">
    <div class="cash-history-header">
        <div class="cash-history-title-block">
            <span class="cash-history-title-icon" aria-hidden="true">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </span>
            <div>
                <h2 class="mb-0">Historial de cierres</h2>
                <span>Consulta cierres anteriores y diferencias de caja</span>
            </div>
        </div>
        <button class="btn btn-outline-secondary cash-history-secondary-action" @onclick="GoToCurrent"><i class="fa-solid fa-cash-register me-1" aria-hidden="true"></i>Caja actual</button>
    </div>

    <ErrorAlert Message="@_error" />

    <div class="card border-0 shadow-sm mb-3 cash-history-filter-card">
        <div class="card-body cash-history-filter-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label" for="historyFrom">Desde</label>
                    <InputDate id="historyFrom" class="form-control" @bind-Value="_from" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label" for="historyTo">Hasta</label>
                    <InputDate id="historyTo" class="form-control" @bind-Value="_to" />
                </div>
                <div class="col-12 col-md-4">
                    <button class="btn btn-primary w-100 cash-history-primary-action" disabled="@_loading" @onclick="LoadHistoryAsync"><i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>
                        @(_loading ? "Consultando..." : "Consultar")
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5 cash-history-loading">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Consultando...</span>
            </div>
        </div>
    }
    else if (_sessions.Count == 0)
    {
        <div class="cash-history-empty">
            <span class="cash-history-empty-icon" aria-hidden="true">
                <i class="fa-solid fa-calendar-xmark"></i>
            </span>
            <div>
                <strong>No hay cierres de caja para el rango seleccionado.</strong>
                <small>Ajusta las fechas y consulta nuevamente.</small>
            </div>
        </div>
    }
    else
    {
        <div class="cash-history-table-card">
            <div class="cash-history-table-header">
                <div>
                    <strong>Cierres registrados</strong>
                    <small>@_sessions.Count resultados en el rango seleccionado</small>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle cash-history-table">
                    <caption>Historial de cierres de caja por rango de fechas</caption>
                    <thead>
                        <tr>
                            <th>Caja</th>
                            <th>Apertura</th>
                            <th>Cierre</th>
                            <th class="text-end">Ventas efectivo</th>
                            <th class="text-end">Gastos</th>
                            <th class="text-end">Retiros</th>
                            <th class="text-end">Reembolsos</th>
                            <th class="text-end">Esperado</th>
                            <th class="text-end">Contado</th>
                            <th class="text-end">Diferencia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in _sessions)
                        {
                        <tr>
                            <td data-label="Caja">
                                <span class="cash-history-register">@session.CashRegisterCode</span>
                            </td>
                            <td data-label="Apertura">@session.OpenedAtUtc.ToLocalTime().ToString("g")</td>
                            <td data-label="Cierre">@session.ClosedAtUtc?.ToLocalTime().ToString("g")</td>
                            <td class="text-end" data-label="Ventas efectivo">RD$ @session.CashSales.ToString("N2")</td>
                            <td class="text-end" data-label="Gastos">RD$ @session.Expenses.ToString("N2")</td>
                            <td class="text-end" data-label="Retiros">RD$ @session.Withdrawals.ToString("N2")</td>
                            <td class="text-end" data-label="Reembolsos">RD$ @session.Refunds.ToString("N2")</td>
                            <td class="text-end" data-label="Esperado">RD$ @session.ExpectedCash.ToString("N2")</td>
                            <td class="text-end" data-label="Contado">RD$ @session.CountedCash?.ToString("N2")</td>
                            <td class="text-end" data-label="Diferencia">
                                <span class="cash-history-difference @(session.Difference.GetValueOrDefault() < 0 ? "negative" : "positive")">
                                    RD$ @session.Difference?.ToString("N2")
                                </span>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private Guid _cashRegisterId;
    private DateTime? _from = DateTime.Today.AddDays(-7);
    private DateTime? _to = DateTime.Today;
    private IReadOnlyList<CashSessionSummaryDto> _sessions = [];

    protected override async Task OnInitializedAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _cashRegisterId = contextResult.Value.CashRegisterId;
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        _error = null;

        DateOnly? from = _from is null ? null : DateOnly.FromDateTime(_from.Value);
        DateOnly? to = _to is null ? null : DateOnly.FromDateTime(_to.Value);
        var result = await HistoryHandler.HandleAsync(new GetCashSessionHistoryQuery(_cashRegisterId, from, to));

        if (result.IsFailure)
            _error = result.Error.Description;
        else
            _sessions = result.Value;

        _loading = false;
    }

    private void GoToCurrent() => Navigation.NavigateTo("/cash/current");
}
