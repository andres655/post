@page "/cash/current"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SmallBusinessPOS.Application.Features.CashSessions.GetCashSessionSummary
@using SmallBusinessPOS.Application.Features.CashSessions.RegisterCashWithdrawal
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject GetCashSessionSummaryHandler SummaryHandler
@inject RegisterCashWithdrawalHandler WithdrawalHandler
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Caja actual</PageTitle>

<div class="container-fluid cash-current-page">
    <PageHeader Title="Caja actual"
                Subtitle="Estado del turno, efectivo esperado y movimientos"
                IconClass="fa-solid fa-cash-register"
                HeaderClass="cash-current-header"
                TitleBlockClass="cash-current-title-block"
                IconContainerClass="cash-current-title-icon">
        <Actions>
            <div class="cash-current-actions">
                <button class="btn btn-outline-secondary cash-current-secondary-action" @onclick="GoToPos"><i class="fa-solid fa-cart-shopping me-1" aria-hidden="true"></i>Punto de venta</button>
                <button class="btn btn-outline-secondary cash-current-secondary-action" @onclick="GoToHistory"><i class="fa-solid fa-clock-rotate-left me-1" aria-hidden="true"></i>Historial</button>
                <button class="btn btn-primary cash-current-primary-action" disabled="@(_summary is null)" @onclick="GoToClose"><i class="fa-solid fa-lock me-1" aria-hidden="true"></i>Cerrar caja</button>
            </div>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    <SuccessAlert Message="@_success"
                  CssClass="cash-current-alert success"
                  Role="alert"
                  Dismissible="false" />

    @if (_loading)
    {
        <LoadingState ContainerClass="cash-current-loading" />
    }
    else if (_summary is null)
    {
        <EmptyState Title="No hay caja abierta"
                    Description="Abre la caja para comenzar ventas, gastos y movimientos de efectivo."
                    IconClass="fa-solid fa-lock-open"
                    ContainerClass="cash-current-empty"
                    IconContainerClass="cash-current-empty-icon">
            <button class="btn btn-primary cash-current-primary-action" @onclick="GoToOpen"><i class="fa-solid fa-lock-open me-1" aria-hidden="true"></i>Abrir caja</button>
        </EmptyState>
    }
    else
    {
        <div class="cash-current-summary-strip" aria-label="Resumen de caja actual">
            <div class="cash-current-metric">
                <small>Efectivo esperado</small>
                <strong>RD$ @_summary.ExpectedCash.ToString("N2")</strong>
            </div>
            <div class="cash-current-metric">
                <small>Ventas en efectivo</small>
                <strong>RD$ @_summary.CashSales.ToString("N2")</strong>
            </div>
            <div class="cash-current-metric">
                <small>Retiros y gastos</small>
                <strong>RD$ @((_summary.Withdrawals + _summary.Expenses).ToString("N2"))</strong>
            </div>
        </div>

        <div class="row g-3 cash-current-grid">
            <div class="col-12 col-xl-8">
                <div class="cash-current-summary-card">
                    <CashSummary Summary="_summary" />
                </div>
            </div>
            <AuthorizeView Roles="Supervisor,Administrator">
                <div class="col-12 col-xl-4">
                    <div class="card border-0 shadow-sm cash-current-form-card">
                        <div class="card-header bg-white cash-current-card-header">
                            <span class="cash-current-card-icon" aria-hidden="true">
                                <i class="fa-solid fa-money-bill-transfer"></i>
                            </span>
                            <div>
                                <strong>Registrar retiro</strong>
                                <small>Movimiento de efectivo fuera de caja</small>
                            </div>
                        </div>
                        <div class="card-body cash-current-card-body">
                            <div class="cash-current-guidance">
                                <span>Disponible esperado</span>
                                <strong>RD$ @_summary.ExpectedCash.ToString("N2")</strong>
                            </div>

                            <div class="cash-current-field">
                                <label class="form-label" for="withdrawalAmount">Monto</label>
                                <div class="input-group input-group-lg cash-current-money-input">
                                    <span class="input-group-text">RD$</span>
                                    <InputNumber id="withdrawalAmount" class="form-control" @bind-Value="_withdrawalAmount" />
                                </div>
                            </div>

                            <div class="cash-current-field">
                                <label class="form-label" for="withdrawalReason">Motivo</label>
                                <InputText id="withdrawalReason" class="form-control" @bind-Value="_withdrawalReason" />
                            </div>

                            <div class="cash-current-field">
                                <label class="form-label" for="withdrawalNotes">Notas</label>
                                <textarea id="withdrawalNotes" class="form-control" rows="3" @bind="_withdrawalNotes" placeholder="Detalle opcional del retiro"></textarea>
                            </div>

                            <SaveButton CssClass="btn btn-warning w-100 cash-current-warning-action"
                                        Text="Registrar retiro"
                                        SavingText="Registrando..."
                                        Saving="@_savingWithdrawal"
                                        IconClass="fa-solid fa-money-bill-transfer me-1"
                                        OnClick="RegisterWithdrawalAsync" />
                        </div>
                    </div>
                </div>
            </AuthorizeView>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _savingWithdrawal;
    private string? _error;
    private string? _success;
    private CashSessionSummaryDto? _summary;
    private Guid _cashRegisterId;
    private decimal _withdrawalAmount;
    private string _withdrawalReason = string.Empty;
    private string? _withdrawalNotes;

    protected override async Task OnInitializedAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            _loading = false;
            return;
        }

        _cashRegisterId = contextResult.Value.CashRegisterId;
        await LoadSummaryAsync();
        _loading = false;
    }

    private async Task LoadSummaryAsync()
    {
        var summaryResult = await SummaryHandler.HandleAsync(new GetCashSessionSummaryQuery(_cashRegisterId));

        if (summaryResult.IsFailure)
            _error = summaryResult.Error.Description;
        else
            _summary = summaryResult.Value;
    }

    private async Task RegisterWithdrawalAsync()
    {
        _savingWithdrawal = true;
        _error = null;
        _success = null;

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var result = await WithdrawalHandler.HandleAsync(
            new RegisterCashWithdrawalCommand(_cashRegisterId, _withdrawalAmount, _withdrawalReason, _withdrawalNotes),
            currentUser);

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            _savingWithdrawal = false;
            return;
        }

        _withdrawalAmount = 0m;
        _withdrawalReason = string.Empty;
        _withdrawalNotes = null;
        _success = $"Retiro registrado por RD$ {result.Value.Amount:N2}.";

        await LoadSummaryAsync();
        _savingWithdrawal = false;
    }

    private void GoToPos() => Navigation.NavigateTo("/pos");
    private void GoToHistory() => Navigation.NavigateTo("/cash/history");
    private void GoToClose() => Navigation.NavigateTo("/cash/close");
    private void GoToOpen() => Navigation.NavigateTo("/cash/open");
}
