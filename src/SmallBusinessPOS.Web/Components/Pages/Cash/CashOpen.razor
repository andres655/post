@page "/cash/open"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SmallBusinessPOS.Application.Features.CashSessions.OpenCashSession
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject OpenCashSessionHandler OpenSessionHandler
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Abrir caja</PageTitle>

<div class="container-fluid cash-open-page">
    <PageHeader Title="Abrir caja"
                Subtitle="Inicio de turno y efectivo inicial"
                IconClass="fa-solid fa-lock-open"
                HeaderClass="cash-open-header"
                TitleBlockClass="cash-open-title-block"
                IconContainerClass="cash-open-title-icon">
        <Actions>
            <button class="btn btn-outline-secondary cash-open-secondary-action" @onclick="GoBack"><i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>Volver a caja</button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    @if (_loading)
    {
        <LoadingState ContainerClass="cash-open-loading" />
    }
    else if (_context is not null)
    {
        <div class="row g-3 cash-open-grid">
            <div class="col-12 col-xl-7">
                <div class="card border-0 shadow-sm cash-open-form-card">
                    <div class="card-header bg-white cash-open-card-header">
                        <span class="cash-open-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-cash-register"></i>
                        </span>
                        <div>
                            <strong>Apertura de turno</strong>
                            <small>Confirma la caja y registra el fondo inicial</small>
                        </div>
                    </div>
                    <div class="card-body cash-open-card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="cash-open-readonly-field">
                                    <label class="form-label" for="openBusiness">Negocio</label>
                                    <input id="openBusiness" class="form-control" value="@_context.BusinessName" disabled />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="cash-open-readonly-field">
                                    <label class="form-label" for="openBranch">Sucursal</label>
                                    <input id="openBranch" class="form-control" value="@_context.BranchName" disabled />
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="cash-open-readonly-field">
                                    <label class="form-label" for="openRegister">Caja</label>
                                    <input id="openRegister" class="form-control" value="@_context.CashRegisterCode" disabled />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="cash-open-field">
                                    <label class="form-label fw-semibold" for="openingAmount">Efectivo inicial</label>
                                    <div class="input-group input-group-lg cash-open-money-input">
                                    <span class="input-group-text">RD$</span>
                                        <InputNumber id="openingAmount" class="form-control" @bind-Value="_openingAmount" min="0" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cash-open-footer-actions">
                            <button class="btn btn-outline-secondary cash-open-secondary-action" @onclick="GoBack"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i>Cancelar</button>
                            <SaveButton CssClass="btn btn-primary cash-open-primary-action"
                                        Text="Abrir caja"
                                        SavingText="Abriendo..."
                                        Saving="@_saving"
                                        IconClass="fa-solid fa-lock-open me-1"
                                        OnClick="OpenAsync" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card border-0 shadow-sm h-100 cash-open-guide-card">
                    <div class="card-body cash-open-guide-body">
                        <span class="cash-open-guide-icon" aria-hidden="true">
                            <i class="fa-solid fa-list-check"></i>
                        </span>
                        <div class="cash-open-guide-label">Flujo recomendado</div>
                        <div class="h5 mt-2">Cuenta el efectivo fisico antes de abrir</div>
                        <p class="text-muted mb-0">
                            El monto inicial sera parte del efectivo esperado al cierre de caja.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private PosContextDto? _context;
    private decimal _openingAmount;

    protected override async Task OnInitializedAsync()
    {
        var result = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (result.IsFailure)
        {
            _error = result.Error.Description;
            _loading = false;
            return;
        }

        _context = result.Value;

        if (_context.HasOpenCashSession)
        {
            Navigation.NavigateTo("/cash/current");
            return;
        }

        _loading = false;
    }

    private async Task OpenAsync()
    {
        if (_context is null)
            return;

        _saving = true;
        _error = null;

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var result = await OpenSessionHandler.HandleAsync(
            new OpenCashSessionCommand(
                _context.BusinessId,
                _context.BranchId,
                _context.CashRegisterId,
                _openingAmount),
            currentUser);

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            _saving = false;
            return;
        }

        Navigation.NavigateTo("/cash/current");
    }

    private void GoBack() => Navigation.NavigateTo("/cash/current");
}
