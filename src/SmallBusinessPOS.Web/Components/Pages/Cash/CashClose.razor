@page "/cash/close"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

<PageTitle>Cierre de caja</PageTitle>

<div class="container-fluid cash-close-page">
    <PageHeader Title="Cierre de caja"
                Subtitle="Conteo final, conciliacion y cierre del turno"
                IconClass="fa-solid fa-lock"
                HeaderClass="cash-close-header"
                TitleBlockClass="cash-close-title-block"
                IconContainerClass="cash-close-title-icon"
                TitleClass="mb-0">
        <Actions>
            <button class="btn btn-outline-secondary cash-close-secondary-action" @onclick="GoToCurrent">
                <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>Caja actual
            </button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    <SuccessAlert Message="@_success"
                  CssClass="alert alert-success cash-close-alert success"
                  Role="alert"
                  Dismissible="false" />

    @if (_loading)
    {
        <LoadingState ContainerClass="text-center py-5 cash-close-loading" />
    }
    else if (_summary is null)
    {
        <EmptyState Title="No hay caja abierta para cerrar."
                    Description="Vuelve a caja actual para abrir o revisar el estado del turno."
                    IconClass="fa-solid fa-cash-register"
                    ContainerClass="cash-close-empty"
                    IconContainerClass="cash-close-empty-icon">
            <button class="btn btn-primary cash-close-primary-action" @onclick="GoToCurrent">
                <i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>Caja actual
            </button>
        </EmptyState>
    }
    else
    {
        <div class="cash-close-summary-strip" aria-label="Resumen de cierre">
            <div class="cash-close-metric">
                <small>Efectivo esperado</small>
                <strong>RD$ @_summary.ExpectedCash.ToString("N2")</strong>
            </div>
            <div class="cash-close-metric">
                <small>Efectivo contado</small>
                <strong>@(_closedSession?.DeclaredClosingBalance is decimal counted ? $"RD$ {counted:N2}" : $"RD$ {_countedAmount:N2}")</strong>
            </div>
            <div class="cash-close-metric @(CurrentDifference < 0 ? "negative" : "positive")">
                <small>Diferencia</small>
                <strong>RD$ @CurrentDifference.ToString("N2")</strong>
            </div>
        </div>

        <div class="row g-3 cash-close-grid">
            <div class="col-12 col-xl-8">
                <div class="cash-close-summary-card">
                    <CashSummary Summary="_summary" CountedCash="_closedSession?.DeclaredClosingBalance" Difference="_closedSession?.Difference" />
                </div>
            </div>
            <div class="col-12 col-xl-4">
                <div class="card border-0 shadow-sm cash-close-form-card">
                    <div class="card-header bg-white cash-close-card-header">
                        <span class="cash-close-card-icon" aria-hidden="true">
                            <i class="fa-solid fa-calculator"></i>
                        </span>
                        <div>
                            <strong>Conteo final</strong>
                            <small>Confirma el efectivo antes de cerrar</small>
                        </div>
                    </div>
                    <div class="card-body cash-close-card-body">
                        <div class="cash-close-balance-state @(CurrentDifference < 0 ? "negative" : "positive")">
                            <span>@(CurrentDifference == 0 ? "Caja cuadrada" : "Diferencia detectada")</span>
                            <strong>RD$ @CurrentDifference.ToString("N2")</strong>
                        </div>

                        <div class="cash-close-field">
                            <label class="form-label" for="countedAmount">Efectivo contado</label>
                            <div class="input-group input-group-lg cash-close-money-input">
                                <span class="input-group-text">RD$</span>
                                <InputNumber id="countedAmount" class="form-control" @bind-Value="_countedAmount" disabled="@(_closedSession is not null)" />
                            </div>
                        </div>

                        <div class="cash-close-field">
                            <label class="form-label" for="closeNotes">Notas</label>
                            <textarea id="closeNotes" class="form-control" rows="4" @bind="_notes" disabled="@(_closedSession is not null)" placeholder="Observaciones del cierre"></textarea>
                        </div>

                        <button class="btn btn-danger w-100 cash-close-danger-action" disabled="@(_closing || _closedSession is not null)" @onclick="CloseAsync">
                            <i class="fa-solid fa-lock me-1" aria-hidden="true"></i>
                            @(_closing ? "Cerrando..." : "Cerrar caja")
                        </button>

                        @if (_closedSession is not null)
                        {
                            <div class="cash-close-closed-note">
                                <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                                Caja cerrada correctamente.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

