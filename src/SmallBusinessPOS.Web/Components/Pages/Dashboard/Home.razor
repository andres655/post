@page "/"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

<PageTitle>Dashboard Principal</PageTitle>

<div class="control-screen">
    <PageHeader Title="Dashboard Principal"
                IconClass="fa-solid fa-house-chimney-window"
                HeadingLevel="1"
                HeaderClass="control-hero"
                TitleBlockClass="control-hero-title"
                IconContainerClass="control-hero-icon">
        <SubtitleContent>
            <p>Resumen operativo para el dia de hoy, @TodayLabel.</p>
        </SubtitleContent>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    @if (_loading)
    {
        <LoadingState Label="Cargando dashboard principal..." ContainerClass="control-loading" />
    }
    else if (_dashboard is not null)
    {
        <section class="control-kpis" aria-label="Indicadores principales del dia">
            <article class="control-kpi">
                <div>
                    <span>Ventas del Dia</span>
                    <strong>@Money(_dashboard.Kpis.TodaySales)</strong>
                    <small><i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i> @WeeklyShareLabel participacion semanal</small>
                </div>
                <i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i>
            </article>

            <article class="control-kpi">
                <div>
                    <span>Transacciones</span>
                    <strong>@_dashboard.Kpis.TodaySalesCount.ToString("N0")</strong>
                    <small>Promedio: @TransactionsPerHour.ToString("N0")/hora</small>
                </div>
                <i class="fa-solid fa-receipt" aria-hidden="true"></i>
            </article>

            <article class="control-kpi">
                <div>
                    <span>Ticket Promedio</span>
                    <strong>@Money(AverageTicket)</strong>
                    <small><i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i> Margen @_dashboard.Kpis.TodayGrossMarginPercent.ToString("N1")%</small>
                </div>
                <i class="fa-solid fa-chart-column" aria-hidden="true"></i>
            </article>

            <article class="control-kpi warning">
                <div>
                    <span>Bajo Stock</span>
                    <strong>@_dashboard.Kpis.LowStockCount.ToString("00")</strong>
                    <small>Requiere atencion</small>
                </div>
                <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
            </article>
        </section>

        <section class="control-main-grid" aria-label="Rendimiento y accesos rapidos">
            <article class="control-week-card">
                <div class="control-card-header">
                    <div>
                        <strong>Rendimiento Semanal</strong>
                        <small>Vista visual estimada con ventas de la semana</small>
                    </div>
                    <span>Ultimos 7 dias</span>
                </div>
                <div class="control-chart" aria-label="Grafico de rendimiento semanal">
                    @foreach (var bar in WeekBars)
                    {
                        <div class="control-chart-bar">
                            <span style="height:@bar.Height%"></span>
                            <small>@bar.Label</small>
                        </div>
                    }
                </div>
            </article>

            <aside class="control-quick-card">
                <div class="control-quick-header">
                    <h2>Acceso Rapido</h2>
                    <span>Acciones frecuentes</span>
                </div>
                <button type="button" class="control-quick-action primary" @onclick="GoToPos">
                    <span><i class="fa-solid fa-cart-shopping" aria-hidden="true"></i></span>
                    <strong>Nueva Venta</strong>
                    <small>F1 para atajo</small>
                </button>
                <AuthorizeView Roles="Administrator">
                    <button type="button" class="control-quick-action" @onclick="GoToProducts">
                        <span><i class="fa-regular fa-square-plus" aria-hidden="true"></i></span>
                        <strong>Registrar Producto</strong>
                        <small>Actualizar inventario</small>
                    </button>
                </AuthorizeView>
                <button type="button" class="control-quick-action" @onclick="GoToCash">
                    <span class="danger"><i class="fa-solid fa-cash-register" aria-hidden="true"></i></span>
                    <strong>Cierre de Caja</strong>
                    <small>Finalizar jornada</small>
                </button>
            </aside>
        </section>

        <section class="control-sales-card" aria-label="Ventas recientes">
            <div class="control-card-header">
                <div>
                    <strong>Ventas Recientes</strong>
                    <small>Ultimos movimientos registrados hoy</small>
                </div>
                <button type="button" @onclick="GoToDailyReport">Ver todas</button>
            </div>
            <div class="table-responsive">
                <table class="control-sales-table">
                    <caption>Ventas recientes del dia con hora, ticket, cliente, total y estado</caption>
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Ticket #</th>
                            <th>Cliente</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in RecentRows)
                        {
                            <tr>
                                <td data-label="Hora">@item.OccurredAtUtc.ToLocalTime().ToString("HH:mm")</td>
                                <td data-label="Ticket">@item.Reference</td>
                                <td data-label="Cliente">@item.Area</td>
                                <td data-label="Total"><strong>@(item.Amount.HasValue ? Money(item.Amount.Value) : "-")</strong></td>
                                <td data-label="Estado"><span class="control-status">Pagado</span></td>
                                <td class="text-end control-row-menu"><i class="fa-solid fa-ellipsis-vertical" aria-hidden="true"></i></td>
                            </tr>
                        }
                        @if (!RecentRows.Any())
                        {
                            <tr>
                                <td colspan="6" class="control-empty">
                                    <EmptyState Title="Sin ventas recientes."
                                                IconClass="fa-solid fa-circle-info"
                                                ContainerClass="control-empty-state" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

