@page "/analytics"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Reports.GetManagementDashboard

@inject GetPosContextHandler PosContextHandler
@inject GetManagementDashboardHandler DashboardHandler
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Reportes y Analitica</PageTitle>

<div class="analytics-screen">
    <section class="analytics-hero">
        <div>
            <h1>Reportes y Analitica</h1>
            <p>Monitorea el rendimiento de tu negocio en tiempo real.</p>
        </div>

        <div class="analytics-controls">
            <div class="analytics-periods" aria-label="Rango de reportes">
                <button type="button" @onclick="LoadDashboardAsync">Hoy</button>
                <button type="button" class="active" aria-current="true">7 dias</button>
                <button type="button" @onclick="GoToProfitability">Mes</button>
                <button type="button" @onclick="GoToProfitability"><i class="fa-regular fa-calendar" aria-hidden="true"></i>Personalizado</button>
            </div>
            <button type="button" class="analytics-export" aria-label="Exportar reporte de rentabilidad" @onclick="ExportProfitabilityCsv">
                <i class="fa-solid fa-download" aria-hidden="true"></i>
                Exportar
            </button>
        </div>
    </section>

    @if (_showGuidance)
    {
        <div class="analytics-guidance">
            <span>@_guidanceText</span>
            <button type="button" aria-label="Cerrar guia" @onclick="HideGuidance"><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
        </div>
    }

    <ErrorAlert Message="@_error" />

    @if (_loading)
    {
        <div class="analytics-loading"><div class="spinner-border text-success"></div></div>
    }
    else if (_dashboard is not null)
    {
        <section class="analytics-kpis">
            <article class="analytics-kpi">
                <div class="analytics-kpi-top">
                    <span class="analytics-kpi-icon green"><i class="fa-solid fa-money-bill-trend-up" aria-hidden="true"></i></span>
                    <span class="analytics-delta good">+@SalesTransactionRatio.ToString("N1")%</span>
                </div>
                <span class="analytics-kpi-label">Ingresos Totales</span>
                <strong>@Money(_dashboard.Kpis.WeekSales)</strong>
                <div class="analytics-progress"><span style="width:@ProgressWidth(_dashboard.Kpis.WeekSales, _dashboard.Kpis.WeekSales + _dashboard.Kpis.TodayExpenses)%"></span></div>
            </article>

            <article class="analytics-kpi">
                <div class="analytics-kpi-top">
                    <span class="analytics-kpi-icon blue"><i class="fa-solid fa-arrow-trend-up" aria-hidden="true"></i></span>
                    <span class="analytics-delta good">+@NetProfitRatio.ToString("N1")%</span>
                </div>
                <span class="analytics-kpi-label">Ganancia Neta</span>
                <strong>@Money(_dashboard.Kpis.WeekNetProfit)</strong>
                <div class="analytics-progress dark"><span style="width:@ProgressWidth(_dashboard.Kpis.WeekNetProfit, _dashboard.Kpis.WeekSales)%"></span></div>
            </article>

            <article class="analytics-kpi">
                <div class="analytics-kpi-top">
                    <span class="analytics-kpi-icon amber"><i class="fa-solid fa-chart-pie" aria-hidden="true"></i></span>
                    <span class="analytics-delta bad">@(_dashboard.Kpis.TodayGrossMarginPercent < 0 ? string.Empty : "+")@_dashboard.Kpis.TodayGrossMarginPercent.ToString("N1")%</span>
                </div>
                <span class="analytics-kpi-label">Margen de Utilidad</span>
                <strong>@_dashboard.Kpis.TodayGrossMarginPercent.ToString("N1")%</strong>
                <div class="analytics-progress amber"><span style="width:@ProgressWidth(_dashboard.Kpis.TodayGrossMarginPercent, 100)%"></span></div>
            </article>
        </section>

        <section class="analytics-grid">
            <article class="analytics-card analytics-donut-card">
                <div class="analytics-card-header">
                    <strong>Composicion del Dia</strong>
                    <button type="button" aria-label="Opciones de composicion"><i class="fa-solid fa-ellipsis-vertical" aria-hidden="true"></i></button>
                </div>

                <div class="analytics-donut-layout">
                    <div class="analytics-donut" style="@DonutStyle">
                        <div>
                            <span>Total</span>
                            <strong>@CompactMoney(_dashboard.Kpis.TodaySales)</strong>
                        </div>
                    </div>
                    <div class="analytics-legend">
                        <div><span class="dot black"></span><span>Ventas</span><strong>@PercentOf(_dashboard.Kpis.TodaySales, CompositionTotal).ToString("N0")%</strong></div>
                        <div><span class="dot green"></span><span>Utilidad</span><strong>@PercentOf(_dashboard.Kpis.TodayNetProfit, CompositionTotal).ToString("N0")%</strong></div>
                        <div><span class="dot amber"></span><span>Gastos</span><strong>@PercentOf(_dashboard.Kpis.TodayExpenses, CompositionTotal).ToString("N0")%</strong></div>
                    </div>
                </div>
            </article>

            <article class="analytics-card">
                <div class="analytics-card-header">
                    <strong>Productos Mas Vendidos</strong>
                    <button type="button" @onclick="GoToDailyReport">Ver</button>
                </div>

                <div class="analytics-top-products">
                    @foreach (var item in _dashboard.TopProducts.Take(4))
                    {
                        <div class="analytics-product-row">
                            <div>
                                <span>@item.ProductName</span>
                                <strong>@item.Quantity.ToString("N0") u.</strong>
                            </div>
                            <div class="analytics-product-bar"><span style="width:@ProductBarWidth(item)%"></span></div>
                        </div>
                    }
                    @if (_dashboard.TopProducts.Count == 0)
                    {
                        <div class="analytics-empty">Sin ventas confirmadas hoy.</div>
                    }
                </div>
            </article>
        </section>

        <section class="analytics-table-card">
            <div class="analytics-card-header">
                <strong>Rendimiento Operativo</strong>
                <button type="button" @onclick="GoToProfitability">Ver todo <i class="fa-solid fa-chevron-right" aria-hidden="true"></i></button>
            </div>
                <div class="table-responsive">
                    <table class="analytics-table">
                        <caption>Indicadores de rendimiento operativo del negocio</caption>
                        <thead>
                        <tr>
                            <th>Indicador</th>
                            <th>Ventas Totales</th>
                            <th>Transacciones</th>
                            <th>Promedio Ticket</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Dia actual</td>
                            <td>@Money(_dashboard.Kpis.TodaySales)</td>
                            <td>@_dashboard.Kpis.TodaySalesCount.ToString("N0")</td>
                            <td>@Money(AverageTicket)</td>
                            <td><span class="analytics-status ok">Activo</span></td>
                        </tr>
                        <tr>
                            <td>Semana movil</td>
                            <td>@Money(_dashboard.Kpis.WeekSales)</td>
                            <td>-</td>
                            <td>@Money(_dashboard.Kpis.WeekNetProfit)</td>
                            <td><span class="analytics-status ok">7 dias</span></td>
                        </tr>
                        <tr>
                            <td>Caja</td>
                            <td>@Money(_dashboard.Kpis.ExpectedCash)</td>
                            <td>@(_dashboard.Kpis.HasOpenCashSession ? "Abierta" : "Cerrada")</td>
                            <td>@Money(_dashboard.Kpis.TodayExpenses)</td>
                            <td><span class="analytics-status @(_dashboard.Kpis.HasOpenCashSession ? "ok" : "warn")">@(_dashboard.Kpis.HasOpenCashSession ? "Operando" : "Cerrada")</span></td>
                        </tr>
                        <tr>
                            <td>Inventario bajo</td>
                            <td>@_dashboard.Kpis.LowStockCount.ToString("N0") productos</td>
                            <td>@_dashboard.LowStockItems.Count.ToString("N0") alertas</td>
                            <td>-</td>
                            <td><span class="analytics-status @(_dashboard.Kpis.LowStockCount > 0 ? "warn" : "ok")">@(_dashboard.Kpis.LowStockCount > 0 ? "Atencion" : "Normal")</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private bool _showGuidance = true;
    private string? _error;
    private ManagementDashboardDto? _dashboard;
    private string _guidanceText = "Aqui veras tus KPIs del dia y tus acciones mas importantes.";

    private decimal AverageTicket => _dashboard is null || _dashboard.Kpis.TodaySalesCount == 0
        ? 0
        : _dashboard.Kpis.TodaySales / _dashboard.Kpis.TodaySalesCount;

    private decimal CompositionTotal => _dashboard is null
        ? 0
        : Math.Abs(_dashboard.Kpis.TodaySales) + Math.Abs(_dashboard.Kpis.TodayNetProfit) + Math.Abs(_dashboard.Kpis.TodayExpenses);

    private decimal SalesTransactionRatio => _dashboard is null || _dashboard.Kpis.WeekSales <= 0
        ? 0
        : Math.Min(99, (_dashboard.Kpis.TodaySales / _dashboard.Kpis.WeekSales) * 100);

    private decimal NetProfitRatio => _dashboard is null || _dashboard.Kpis.WeekSales <= 0
        ? 0
        : (_dashboard.Kpis.WeekNetProfit / _dashboard.Kpis.WeekSales) * 100;

    private string DonutStyle
    {
        get
        {
            if (_dashboard is null || CompositionTotal <= 0)
                return "background: conic-gradient(#e5e7eb 0 100%);";

            var sales = PercentOf(_dashboard.Kpis.TodaySales, CompositionTotal);
            var profit = PercentOf(_dashboard.Kpis.TodayNetProfit, CompositionTotal);
            var salesEnd = sales;
            var profitEnd = sales + profit;
            return $"background: conic-gradient(#020617 0 {salesEnd:N2}%, #007f55 {salesEnd:N2}% {profitEnd:N2}%, #f59e0b {profitEnd:N2}% 100%);";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
        await ConfigureGuidanceAsync();
    }

    private async Task ConfigureGuidanceAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.IsInRole("Administrator"))
            _guidanceText = "Administra usuarios, catalogo y caja desde los indicadores principales.";
        else if (user.IsInRole("Supervisor"))
            _guidanceText = "Revisa inventario, produccion y rentabilidad para mantener control operativo.";
        else
            _guidanceText = "Abre la caja y usa el punto de venta para registrar operaciones diarias.";
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var context = await PosContextHandler.HandleAsync(new GetPosContextQuery());
            if (context.IsFailure)
            {
                _error = context.Error.Description;
                return;
            }

            var result = await DashboardHandler.HandleAsync(new GetManagementDashboardQuery(
                context.Value.BusinessId,
                context.Value.BranchId,
                DateOnly.FromDateTime(DateTime.UtcNow)));

            if (result.IsFailure)
                _error = result.Error.Description;
            else
                _dashboard = result.Value;
        }
        catch
        {
            _error = "No se pudo cargar el dashboard.";
        }
        finally
        {
            _loading = false;
        }
    }

    private string Money(decimal value) => $"RD$ {value:N2}";

    private static string CompactMoney(decimal value)
    {
        var abs = Math.Abs(value);
        if (abs >= 1_000_000)
            return $"RD$ {(value / 1_000_000):N1}M";
        if (abs >= 1_000)
            return $"RD$ {(value / 1_000):N0}K";

        return $"RD$ {value:N0}";
    }

    private static decimal PercentOf(decimal value, decimal total)
    {
        if (total <= 0)
            return 0;

        return Math.Clamp((Math.Abs(value) / total) * 100, 0, 100);
    }

    private static decimal ProgressWidth(decimal value, decimal total)
    {
        if (total <= 0)
            return 0;

        return Math.Clamp((Math.Abs(value) / Math.Abs(total)) * 100, 4, 100);
    }

    private decimal ProductBarWidth(DashboardProductDto item)
    {
        if (_dashboard is null || _dashboard.TopProducts.Count == 0)
            return 0;

        var max = _dashboard.TopProducts.Max(product => product.Quantity);
        return ProgressWidth(item.Quantity, max);
    }

    private void GoToDailyReport() => Navigation.NavigateTo("/reports/daily");
    private void GoToProfitability() => Navigation.NavigateTo("/reports/profitability");
    private void HideGuidance() => _showGuidance = false;

    private void ExportProfitabilityCsv()
    {
        var to = DateTime.Today;
        var from = to.AddDays(-6);
        Navigation.NavigateTo($"/api/reports/profitability/{from:yyyy-MM-dd}/{to:yyyy-MM-dd}/csv", forceLoad: true);
    }
}
