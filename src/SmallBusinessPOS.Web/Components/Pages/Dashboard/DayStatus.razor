@page "/day-status"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using SmallBusinessPOS.Application.Features.Reports.GetManagementDashboard
@using SmallBusinessPOS.Application.Features.Settings.GetBusinessSettings

@inject GetPosContextHandler PosContextHandler
@inject GetManagementDashboardHandler DashboardHandler
@inject GetBusinessSettingsHandler GetSettingsHandler
@inject NavigationManager Navigation

<PageTitle>Estado del día</PageTitle>

<div class="container-fluid day-status-page">
    <PageHeader Title="Estado del día"
                IconClass="fa-solid fa-clipboard-check"
                HeaderClass="day-status-header"
                TitleBlockClass="day-status-title-block"
                IconContainerClass="day-status-title-icon">
        <SubtitleContent>
            <span class="day-status-subtitle">Resumen operativo para el turno actual</span>
            @if (_context is not null)
            {
                <span class="day-status-branch">@_context.BusinessName / @_context.BranchName</span>
            }
        </SubtitleContent>
        <Actions>
        <div class="day-status-actions">
            <button class="btn btn-dark day-status-primary-action" @onclick="GoToPos">
                <i class="fa-solid fa-cart-shopping me-1"></i>POS
            </button>
            <SaveButton CssClass="btn btn-outline-secondary day-status-secondary-action"
                        Text="Actualizar"
                        SavingText="Actualizando..."
                        Saving="@_loading"
                        IconClass="fa-solid fa-rotate me-1"
                        OnClick="LoadAsync" />
        </div>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@_error" />

    @if (_loading)
    {
        <LoadingState Label="Cargando estado del dia..." ContainerClass="day-status-loading" />
    }
    else if (_dashboard is not null)
    {
        <div class="day-status-grid">
            <section class="day-status-card @(_dashboard.Kpis.HasOpenCashSession ? "status-ok" : "status-warn")">
                <div class="day-status-card-title">
                    <i class="fa-solid fa-cash-register"></i>
                    <span>Caja</span>
                </div>
                <strong>@(_dashboard.Kpis.HasOpenCashSession ? "Abierta" : "Cerrada")</strong>
                <small>Efectivo esperado: @Money(_dashboard.Kpis.ExpectedCash)</small>
                <button class="btn btn-sm btn-outline-secondary day-status-card-action" @onclick="GoToCash">
                    Ver caja
                </button>
            </section>

            <section class="day-status-card">
                <div class="day-status-card-title">
                    <i class="fa-solid fa-receipt"></i>
                    <span>Ventas</span>
                </div>
                <strong>@Money(_dashboard.Kpis.TodaySales)</strong>
                <small>@_dashboard.Kpis.TodaySalesCount transacciones</small>
                <button class="btn btn-sm btn-outline-secondary day-status-card-action" @onclick="GoToDailyReport">
                    Ver reporte
                </button>
            </section>

            <section class="day-status-card @(_dashboard.Kpis.TodayExpenses > 0 ? "status-info" : string.Empty)">
                <div class="day-status-card-title">
                    <i class="fa-solid fa-money-bill-wave"></i>
                    <span>Gastos</span>
                </div>
                <strong>@Money(_dashboard.Kpis.TodayExpenses)</strong>
                <small>Registrados hoy</small>
                <button class="btn btn-sm btn-outline-secondary day-status-card-action" @onclick="GoToExpenses">
                    Ver gastos
                </button>
            </section>

            <section class="day-status-card @(_dashboard.Kpis.LowStockCount > 0 ? "status-warn" : "status-ok")">
                <div class="day-status-card-title">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span>Inventario bajo</span>
                </div>
                <strong>@_dashboard.Kpis.LowStockCount</strong>
                <small>productos en alerta</small>
                <button class="btn btn-sm btn-outline-secondary day-status-card-action" @onclick="GoToInventory">
                    Ver inventario
                </button>
            </section>
        </div>

        <div class="row g-3 day-status-content">
            <div class="col-12 col-xl-7">
                <div class="card border-0 day-status-panel">
                    <div class="card-header day-status-panel-header">
                        <div>
                            <strong>Productos con inventario bajo</strong>
                            <span>Prioriza reposicion antes de vender.</span>
                        </div>
                        <span class="day-status-count-badge">@_dashboard.LowStockItems.Count visibles</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm align-middle mb-0 day-status-table">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Actual</th>
                                    <th class="text-end">Minimo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _dashboard.LowStockItems)
                                {
                                    <tr>
                                        <td data-label="Producto">
                                            <code>@item.ProductCode</code>
                                            <div class="fw-semibold">@item.ProductName</div>
                                        </td>
                                        <td class="text-end" data-label="Actual">@item.Quantity.ToString("N2")</td>
                                        <td class="text-end" data-label="Minimo">@item.MinimumQuantity.ToString("N2")</td>
                                    </tr>
                                }
                                @if (_dashboard.LowStockItems.Count == 0)
                                {
                                    <tr class="day-status-empty-row">
                                        <td colspan="3">
                                            <EmptyState Title="Sin productos por debajo del minimo."
                                                        IconClass="fa-solid fa-circle-check"
                                                        ContainerClass="day-status-empty-state"
                                                        IconContainerClass="" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card border-0 day-status-panel">
                    <div class="card-header day-status-panel-header">
                        <div>
                            <strong>Resumen rapido</strong>
                            <span>Lectura financiera del dia.</span>
                        </div>
                    </div>
                    <div class="card-body day-status-summary">
                        <div class="metric-row"><span>Ventas</span><strong>@Money(_dashboard.Kpis.TodaySales)</strong></div>
                        <div class="metric-row"><span>Gastos</span><strong>@Money(_dashboard.Kpis.TodayExpenses)</strong></div>
                        <div class="metric-row highlight"><span>Utilidad estimada</span><strong>@Money(_dashboard.Kpis.TodayNetProfit)</strong></div>
                        <div class="metric-row"><span>Margen bruto</span><strong>@_dashboard.Kpis.TodayGrossMarginPercent.ToString("N2")%</strong></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private PosContextDto? _context;
    private ManagementDashboardDto? _dashboard;
    private string _currencySymbol = "RD$";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
            if (contextResult.IsFailure)
            {
                _error = contextResult.Error.Description;
                return;
            }

            _context = contextResult.Value;
            var settingsResult = await GetSettingsHandler.HandleAsync(
                new GetBusinessSettingsQuery(_context.BusinessId, _context.BranchId));
            if (settingsResult.IsSuccess)
                _currencySymbol = string.IsNullOrWhiteSpace(settingsResult.Value.CurrencySymbol) ? "RD$" : settingsResult.Value.CurrencySymbol;

            var dashboardResult = await DashboardHandler.HandleAsync(new GetManagementDashboardQuery(
                _context.BusinessId,
                _context.BranchId,
                DateOnly.FromDateTime(DateTime.UtcNow)));

            if (dashboardResult.IsFailure)
                _error = dashboardResult.Error.Description;
            else
                _dashboard = dashboardResult.Value;
        }
        catch
        {
            _error = "No se pudo cargar el estado del día.";
        }
        finally
        {
            _loading = false;
        }
    }

    private string Money(decimal value) => $"{_currencySymbol} {value:N2}";
    private void GoToPos() => Navigation.NavigateTo("/pos");
    private void GoToCash() => Navigation.NavigateTo("/cash/current");
    private void GoToDailyReport() => Navigation.NavigateTo("/reports/daily");
    private void GoToExpenses() => Navigation.NavigateTo("/expenses");
    private void GoToInventory() => Navigation.NavigateTo("/inventory");
}
