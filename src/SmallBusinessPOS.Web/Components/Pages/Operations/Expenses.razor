@page "/expenses"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Cashier,Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SmallBusinessPOS.Application.Features.Expenses.GetExpenses
@using SmallBusinessPOS.Application.Features.Expenses.RegisterExpense
@using SmallBusinessPOS.Application.Features.POS.GetPosContext
@using System.Security.Claims

@inject GetPosContextHandler PosContextHandler
@inject RegisterExpenseHandler RegisterExpenseHandler
@inject GetExpensesHandler GetExpensesHandler
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Gastos</PageTitle>

<div class="container-fluid expenses-page">
    <div class="expenses-header">
        <div class="expenses-title-block">
            <div class="expenses-title-icon" aria-hidden="true">
                <i class="fa-solid fa-receipt"></i>
            </div>
            <div>
                <h2>Gastos</h2>
                <span>Registra salidas operativas y consulta los movimientos recientes.</span>
            </div>
        </div>
        @if (_context is not null)
        {
            <span class="expenses-session-status @(_context.HasOpenCashSession ? "open" : "closed")">
                <i class="fa-solid @(_context.HasOpenCashSession ? "fa-circle-check" : "fa-triangle-exclamation")" aria-hidden="true"></i>
                <span>@(_context.HasOpenCashSession ? "Caja abierta" : "Caja cerrada")</span>
            </span>
        }
    </div>

    <ErrorAlert Message="@_error" />
    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <div class="expenses-alert success" role="status">
            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
            <span>@_success</span>
        </div>
    }

    <div class="expenses-workspace">
        <div class="expenses-form-column">
            <div class="card border-0 expenses-panel expenses-register-panel">
                <div class="expenses-panel-header">
                    <div>
                        <strong>Registrar gasto</strong>
                        <span>Completa la información del desembolso.</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="expenses-form-grid">
                        <div>
                            <label class="form-label" for="expense-category">Categoría</label>
                            <input id="expense-category" class="form-control" @bind="_category" placeholder="Ej: Combustible" />
                        </div>
                        <div>
                            <label class="form-label" for="expense-concept">Concepto</label>
                            <input id="expense-concept" class="form-control" @bind="_concept" placeholder="Ej: Compra de gas" />
                        </div>
                        <div>
                            <label class="form-label" for="expense-amount">Monto</label>
                            <InputNumber id="expense-amount" class="form-control expenses-amount-input" @bind-Value="_amount" />
                        </div>
                        <div>
                            <label class="form-label" for="expense-notes">Notas</label>
                            <textarea id="expense-notes" class="form-control" rows="3" @bind="_notes"></textarea>
                        </div>
                    </div>

                    <div class="expenses-cash-option">
                        <input id="paidFromCash" class="form-check-input" type="checkbox" @bind="_paidFromCash" />
                        <label class="form-check-label" for="paidFromCash">
                            <span>Pagado desde caja</span>
                            <small>Actualiza el efectivo esperado cuando aplica.</small>
                        </label>
                    </div>

                    <button class="btn expenses-primary-action" disabled="@_saving" @onclick="RegisterAsync"><i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        @(_saving ? "Guardando..." : "Registrar gasto")
                    </button>
                </div>
            </div>
        </div>

        <div class="expenses-history-column">
            <div class="card border-0 expenses-panel">
                <div class="expenses-panel-header expenses-history-header">
                    <div>
                        <strong>Gastos recientes</strong>
                        <span>Consulta por rango y revisa el total acumulado.</span>
                    </div>
                    <div class="expenses-filters">
                        <input class="form-control" type="date" @bind="_fromDate" />
                        <input class="form-control" type="date" @bind="_toDate" />
                        <button class="btn expenses-secondary-action" @onclick="LoadExpensesAsync"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>Buscar</button>
                    </div>
                </div>
                <div class="expenses-total-strip">
                    <span>Total del rango</span>
                    <strong>RD$ @_expenses.Sum(e => e.Amount).ToString("N2")</strong>
                </div>
                <div class="card-body p-0">
                    @if (_loading)
                    {
                        <div class="expenses-loading">
                            <div class="spinner-border text-primary" aria-hidden="true"></div>
                            <span>Cargando gastos...</span>
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover align-middle mb-0 expenses-table">
                            <caption>Gastos recientes por rango seleccionado</caption>
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Categoría</th>
                                    <th>Concepto</th>
                                    <th>Caja</th>
                                    <th class="text-end">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var expense in _expenses)
                                {
                                    <tr>
                                        <td data-label="Fecha">@expense.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td data-label="Categoría"><span class="expenses-category-chip">@expense.Category</span></td>
                                        <td data-label="Concepto">
                                            <div class="expenses-concept">@expense.Concept</div>
                                            @if (!string.IsNullOrWhiteSpace(expense.Notes))
                                            {
                                                <small>@expense.Notes</small>
                                            }
                                        </td>
                                        <td data-label="Caja">
                                            <span class="expenses-cash-badge @(expense.PaidFromCash ? "paid" : "external")">
                                                @(expense.PaidFromCash ? "Sí" : "No")
                                            </span>
                                        </td>
                                        <td class="text-end" data-label="Monto"><strong class="expenses-amount">RD$ @expense.Amount.ToString("N2")</strong></td>
                                    </tr>
                                }
                                @if (_expenses.Count == 0)
                                {
                                    <tr>
                                        <td colspan="5" class="expenses-empty-cell">
                                            <div class="expenses-empty">
                                                <i class="fa-regular fa-folder-open" aria-hidden="true"></i>
                                                <span>No hay gastos en el rango seleccionado.</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="4" class="text-end">Total</th>
                                    <th class="text-end">RD$ @_expenses.Sum(e => e.Amount).ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PosContextDto? _context;
    private List<ExpenseDto> _expenses = [];
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _success;

    private string _category = "Operativo";
    private string _concept = string.Empty;
    private decimal _amount;
    private string? _notes;
    private bool _paidFromCash = true;

    private DateTime _fromDate = DateTime.Today;
    private DateTime _toDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadContextAsync();
        await LoadExpensesAsync();
    }

    private async Task LoadContextAsync()
    {
        var contextResult = await PosContextHandler.HandleAsync(new GetPosContextQuery());
        if (contextResult.IsFailure)
        {
            _error = contextResult.Error.Description;
            return;
        }

        _context = contextResult.Value;
    }

    private async Task LoadExpensesAsync()
    {
        _loading = true;
        _error = null;

        if (_context is null)
            await LoadContextAsync();

        if (_context is null)
        {
            _loading = false;
            return;
        }

        var result = await GetExpensesHandler.HandleAsync(new GetExpensesQuery(
            _context.BusinessId,
            _context.BranchId,
            DateOnly.FromDateTime(_fromDate.Date),
            DateOnly.FromDateTime(_toDate.Date)));

        if (result.IsFailure)
            _error = result.Error.Description;
        else
            _expenses = result.Value;

        _loading = false;
    }

    private async Task RegisterAsync()
    {
        _saving = true;
        _error = null;
        _success = null;

        if (_context is null)
            await LoadContextAsync();

        if (_context is null)
        {
            _saving = false;
            return;
        }

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var result = await RegisterExpenseHandler.HandleAsync(new RegisterExpenseCommand(
            _context.BusinessId,
            _context.BranchId,
            _category,
            _concept,
            _amount,
            _paidFromCash,
            _notes), currentUser);

        if (result.IsFailure)
        {
            _error = result.Error.Description;
            _saving = false;
            return;
        }

        _success = result.Value.ExpectedCash is null
            ? "Gasto registrado correctamente."
            : $"Gasto registrado. Efectivo esperado: RD$ {result.Value.ExpectedCash.Value:N2}.";

        _concept = string.Empty;
        _amount = 0m;
        _notes = null;

        await LoadContextAsync();
        await LoadExpensesAsync();
        _saving = false;
    }
}
