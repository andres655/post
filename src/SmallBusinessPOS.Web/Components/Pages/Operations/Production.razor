@page "/production"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Supervisor,Administrator")]

@using Microsoft.AspNetCore.Authorization
@using SmallBusinessPOS.Web.Services.Pages

@inject ProductionPageService Page

<PageTitle>Producción</PageTitle>

<div class="container-fluid production-page">
    <div class="production-header">
        <div class="production-title-block">
            <div class="production-title-icon" aria-hidden="true">
                <i class="fa-solid fa-industry"></i>
            </div>
            <div>
                <h2>Producción</h2>
                <span>Planifica, confirma, costea y reversa producciones.</span>
            </div>
        </div>
        <span class="production-role-chip">
            <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
            Supervisor / Administrator
        </span>
    </div>

    <ErrorAlert Message="@Page.Error" />
    @if (!string.IsNullOrWhiteSpace(Page.Success))
    {
        <div class="production-alert success" role="status">
            <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
            <span>@Page.Success</span>
        </div>
    }

    <div class="production-kpis mb-3">
        <div class="production-kpi">
            <span>Producido</span>
            <strong>@Page.HistoryProduced.ToString("N2")</strong>
        </div>
        <div class="production-kpi">
            <span>Disponible neto</span>
            <strong>@Page.HistoryNet.ToString("N2")</strong>
        </div>
        <div class="production-kpi">
            <span>Merma</span>
            <strong>@Page.HistoryWaste.ToString("N2")</strong>
        </div>
        <div class="production-kpi">
            <span>Costo total</span>
            <strong>RD$ @Page.HistoryCost.ToString("N2")</strong>
        </div>
    </div>

    <div class="production-workspace">
        <div class="production-form-column">
            <div class="card border-0 production-panel">
                <div class="production-panel-header">
                    <div>
                        <strong>Nueva producción</strong>
                        <span>Si no agregas insumos manuales, se usarán las recetas configuradas.</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label" for="production-date">Fecha</label>
                        <input id="production-date" class="form-control" type="date" @bind="Page.ProductionDate" />
                    </div>

                    <div class="production-lines">
                        @foreach (var line in Page.Lines)
                        {
                            var product = Page.FindProductionProduct(line.ProductId);
                            <div class="production-line">
                                <div class="production-line-header">
                                    <div class="flex-grow-1">
                                        <label class="form-label">Producto producido</label>
                                        <select class="form-select" @bind="line.ProductId" @bind:after="() => Page.ProductChanged(line)">
                                            <option value="@Guid.Empty">Seleccione...</option>
                                            @foreach (var option in Page.Products)
                                            {
                                                <option value="@option.ProductId">@option.Code - @option.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="production-line-actions">
                                        <button class="btn production-secondary-action compact" disabled="@(line.ProductId == Guid.Empty)" @onclick="() => Page.OpenRecipeAsync(line.ProductId)"><i class="fa-solid fa-book-open" aria-hidden="true"></i>Receta</button>
                                        <button class="btn production-danger-outline-action compact" disabled="@(Page.Lines.Count == 1)" @onclick="() => Page.RemoveLine(line)"><i class="fa-solid fa-trash-can" aria-hidden="true"></i>Quitar</button>
                                    </div>
                                </div>

                                <div class="production-line-grid">
                                    <div>
                                        <label class="form-label">Producido</label>
                                        <InputNumber class="form-control text-end" @bind-Value="line.QuantityProduced" />
                                    </div>
                                    <div>
                                        <label class="form-label">Merma</label>
                                        <InputNumber class="form-control text-end" @bind-Value="line.QuantityWasted" />
                                    </div>
                                    <div>
                                        <label class="form-label">Costo unit.</label>
                                        <InputNumber class="form-control text-end" @bind-Value="line.UnitCost" />
                                    </div>
                                </div>

                                <div class="production-line-summary">
                                    <span>Neto <strong>@ProductionPageService.Net(line).ToString("N2")</strong></span>
                                    <span>Costo <strong>RD$ @ProductionPageService.DirectCost(line).ToString("N2")</strong></span>
                                    <span>Margen <strong>@ProductionPageService.ExpectedMarginPercent(line, product).ToString("N2")%</strong></span>
                                </div>
                            </div>
                        }
                    </div>

                    <button class="btn production-secondary-action w-100 mb-3" @onclick="Page.AddLine"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i>Agregar producto</button>

                    <div class="production-input-section">
                        <div class="production-section-heading">
                            <div>
                                <strong>Insumos consumidos</strong>
                                <span>Agrega insumos manuales solo si necesitas ajustar la receta.</span>
                            </div>
                            <button class="btn production-secondary-action compact" @onclick="Page.AddInput"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i>Agregar insumo</button>
                        </div>

                        @if (Page.InputLines.Count == 0)
                        {
                            <div class="empty-state">
                                <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                                <span>Sin insumos manuales. Las recetas calcularán el consumo automáticamente.</span>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive production-input-table-wrap">
                                <table class="table table-sm align-middle production-input-table">
                                    <caption>Insumos manuales consumidos</caption>
                                    <thead>
                                        <tr>
                                            <th>Insumo</th>
                                            <th class="text-end">Cantidad</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var input in Page.InputLines)
                                        {
                                            <tr>
                                                <td data-label="Insumo">
                                                    <select class="form-select form-select-sm" @bind="input.ProductId">
                                                        <option value="@Guid.Empty">Seleccione...</option>
                                                        @foreach (var product in Page.InputProducts)
                                                        {
                                                            <option value="@product.ProductId">@product.Code - @product.Name</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td data-label="Cantidad"><InputNumber class="form-control form-control-sm text-end" @bind-Value="input.Quantity" /></td>
                                                <td class="text-end production-row-actions">
                                                    <button class="btn production-danger-outline-action compact" @onclick="() => Page.RemoveInput(input)"><i class="fa-solid fa-trash-can" aria-hidden="true"></i>Quitar</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="production-notes">Notas</label>
                        <textarea id="production-notes" class="form-control" rows="3" @bind="Page.Notes"></textarea>
                    </div>

                    <div class="production-total mb-3">
                        <div><span>Total producido</span><strong>@Page.FormProduced.ToString("N2")</strong></div>
                        <div><span>Merma</span><strong>@Page.FormWaste.ToString("N2")</strong></div>
                        <div><span>Neto disponible</span><strong>@Page.FormNet.ToString("N2")</strong></div>
                        <div><span>Costo directo</span><strong>RD$ @Page.FormDirectCost.ToString("N2")</strong></div>
                    </div>

                    <button class="btn production-primary-action w-100 production-submit" disabled="@Page.Saving" @onclick="Page.ConfirmAsync">
                        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                        @(Page.Saving ? "Confirmando..." : "Confirmar producción")
                    </button>
                </div>
            </div>
        </div>

        <div class="production-history-column">
            <div class="card border-0 production-panel">
                <div class="production-panel-header production-history-header">
                    <div>
                        <strong>Historial</strong>
                        <span>Producciones, insumos, costos y reversos.</span>
                    </div>
                    <div class="production-history-filters">
                        <input class="form-control" type="date" @bind="Page.HistoryFrom" />
                        <input class="form-control" type="date" @bind="Page.HistoryTo" />
                        <button class="btn production-secondary-action" @onclick="Page.LoadHistoryAsync"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>Consultar</button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0 production-history-table">
                        <caption>Historial de producción</caption>
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th class="text-end">Producido</th>
                                <th class="text-end">Merma</th>
                                <th class="text-end">Neto</th>
                                <th class="text-end">Costo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Page.History)
                            {
                                <tr>
                                    <td data-label="Número">
                                        <strong class="production-entry-number">@entry.Number</strong>
                                        <div class="production-entry-detail">@string.Join(", ", entry.Details.Select(d => $"{d.ProductCode}: {d.NetQuantity:N2}"))</div>
                                        @if (entry.Inputs.Count > 0)
                                        {
                                            <div class="production-entry-detail">Insumos: @string.Join(", ", entry.Inputs.Select(i => $"{i.ProductCode}: {i.Quantity:N2}"))</div>
                                        }
                                    </td>
                                    <td data-label="Fecha">@entry.ProductionDate.ToString("yyyy-MM-dd")</td>
                                    <td data-label="Estado"><span class="production-status @ProductionPageService.GetStatusClass(entry.Status)">@ProductionPageService.GetStatusName(entry.Status)</span></td>
                                    <td class="text-end" data-label="Producido">@entry.TotalProduced.ToString("N2")</td>
                                    <td class="text-end" data-label="Merma">@entry.TotalWasted.ToString("N2")</td>
                                    <td class="text-end" data-label="Neto">@entry.NetAdded.ToString("N2")</td>
                                    <td class="text-end" data-label="Costo">
                                        <strong class="production-cost">RD$ @entry.TotalCost.ToString("N2")</strong>
                                        <div class="production-entry-detail">Directo RD$ @entry.DirectCost.ToString("N2")</div>
                                        <div class="production-entry-detail">Insumos RD$ @entry.InputCost.ToString("N2")</div>
                                        <div class="production-entry-detail">RD$ @entry.CostPerNetUnit.ToString("N2") / unid.</div>
                                    </td>
                                    <td class="text-end production-row-actions">
                                        @if (entry.Status == "Confirmed")
                                        {
                                            <button class="btn production-danger-outline-action compact" @onclick="() => Page.OpenCancel(entry)"><i class="fa-solid fa-ban" aria-hidden="true"></i>Anular</button>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (Page.History.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="production-empty-cell">
                                        <div class="production-empty">
                                            <i class="fa-regular fa-folder-open" aria-hidden="true"></i>
                                            <span>No hay producciones en el rango seleccionado.</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Page.CancelEntry is not null)
{
    <div class="modal fade show d-block production-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 production-modal">
                <div class="modal-header">
                    <h5 class="modal-title">Anular producción</h5>
                    <button type="button" class="btn-close" @onclick="Page.CloseCancel"></button>
                </div>
                <div class="modal-body">
                    <p>Se revertirá el neto agregado de <strong>@Page.CancelEntry.Number</strong> y se reintegrarán los insumos consumidos.</p>
                    <label class="form-label" for="production-cancel-reason">Motivo</label>
                    <InputText id="production-cancel-reason" class="form-control" @bind-Value="Page.CancelReason" />
                </div>
                <div class="modal-footer">
                    <button class="btn production-secondary-action" @onclick="Page.CloseCancel"><i class="fa-solid fa-xmark" aria-hidden="true"></i>Cancelar</button>
                    <button class="btn production-danger-action" disabled="@Page.Saving" @onclick="Page.CancelAsync"><i class="fa-solid fa-ban" aria-hidden="true"></i>Anular</button>
                </div>
            </div>
        </div>
    </div>
}

@if (Page.RecipeProduct is not null)
{
    <div class="modal fade show d-block production-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 production-modal">
                <div class="modal-header">
                    <h5 class="modal-title">Receta de @Page.RecipeProduct.Code</h5>
                    <button type="button" class="btn-close" @onclick="Page.CloseRecipe"></button>
                </div>
                <div class="modal-body">
                    <div class="production-section-heading mb-2">
                        <div>
                            <strong>Cantidad por unidad</strong>
                            <span>Cantidad de cada insumo por 1 unidad producida.</span>
                        </div>
                        <button class="btn production-secondary-action compact" @onclick="Page.AddRecipeLine"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i>Agregar insumo</button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle production-input-table">
                            <caption>Receta de producto</caption>
                            <thead>
                                <tr>
                                    <th>Insumo</th>
                                    <th class="text-end">Cantidad por unidad</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var component in Page.RecipeLines)
                                {
                                    <tr>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="component.ProductId">
                                                <option value="@Guid.Empty">Seleccione...</option>
                                                @foreach (var product in Page.InputProducts.Where(p => p.ProductId != Page.RecipeProduct.ProductId))
                                                {
                                                    <option value="@product.ProductId">@product.Code - @product.Name</option>
                                                }
                                            </select>
                                        </td>
                                        <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="component.Quantity" /></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Page.RemoveRecipeLine(component)"><i class="fa-solid fa-trash-can me-1" aria-hidden="true"></i>Quitar</button>
                                        </td>
                                    </tr>
                                }
                                @if (Page.RecipeLines.Count == 0)
                                {
                                    <tr>
                                        <td colspan="3" class="production-empty-cell">
                                            <div class="production-empty">
                                                <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                                                <span>Esta receta no tiene insumos.</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn production-secondary-action" @onclick="Page.CloseRecipe"><i class="fa-solid fa-xmark" aria-hidden="true"></i>Cancelar</button>
                    <button class="btn production-primary-action" disabled="@Page.Saving" @onclick="Page.SaveRecipeAsync"><i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>Guardar receta</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await Page.InitializeAsync();
    }
}
