@page "/"
@rendermode InteractiveServer

<PageTitle>Dashboard — SmallBusinessPOS</PageTitle>

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <h2 class="mb-0 me-3">Dashboard</h2>
        <span class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-DO"))</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                        <i class="bi bi-cart-check fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Ventas del día</div>
                        <div class="fs-4 fw-bold text-primary">RD$ 0.00</div>
                        <div class="text-muted small">0 transacciones</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                        <i class="bi bi-fire fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Pollos disponibles</div>
                        <div class="fs-4 fw-bold text-success">0</div>
                        <div class="text-muted small">Preparados hoy: 0</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                        <i class="bi bi-cash-coin fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Gastos del día</div>
                        <div class="fs-4 fw-bold text-warning">RD$ 0.00</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3">
                        <i class="bi bi-safe2 fs-4 text-danger"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Caja</div>
                        <div class="fs-4 fw-bold text-danger">Cerrada</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>
        <div>Sistema configurado correctamente. Configure y abra una caja para comenzar a vender.</div>
    </div>
</div>

