@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation

<div class="page @(_navCollapsed ? "nav-collapsed" : string.Empty)">
    <div class="sidebar">
        <button type="button"
                class="sidebar-collapse-button"
                title="@(_navCollapsed ? "Expandir menú" : "Contraer menú")"
                aria-label="@(_navCollapsed ? "Expandir menú" : "Contraer menú")"
                aria-pressed="@_navCollapsed"
                @onclick="ToggleNav">
            <i class="fa-solid @(_navCollapsed ? "fa-angles-right" : "fa-angles-left")" aria-hidden="true"></i>
        </button>
        <NavMenu />
    </div>

    <main>
        <div class="top-row app-terminal-topbar px-4">
            <div class="topbar-title">
                <span class="topbar-page-icon"><i class="fa-solid @CurrentPageIcon" aria-hidden="true"></i></span>
                <span class="topbar-title-copy">
                    <strong>@CurrentPageTitle</strong>
                    <small>CajaPyme</small>
                </span>
                <span class="app-mode-badge"><i class="fa-solid fa-wifi-slash" aria-hidden="true"></i> Modo offline disponible</span>
            </div>
            <div class="topbar-actions">
                <AuthorizeView>
                    <Authorized>
                        <a class="topbar-icon-button" href="/" title="Ayuda" aria-label="Ayuda"><i class="fa-regular fa-circle-question" aria-hidden="true"></i></a>
                        <a class="terminal-chip" href="/cash/current">C01</a>
                        <span class="user-chip">
                            <span class="user-avatar">@GetInitials(context.User.Identity?.Name)</span>
                            <span>@(context.User.Identity?.Name ?? "Usuario")</span>
                        </span>
                        <a class="topbar-icon-button" href="/logout" title="Salir"><i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i></a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Error en la interfaz.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">×</span>
</div>

@code {
    private bool _navCollapsed;
    private string _relativePath = string.Empty;

    private void ToggleNav() => _navCollapsed = !_navCollapsed;

    protected override void OnInitialized()
    {
        UpdateCurrentPath();
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string CurrentPageTitle => _relativePath switch
    {
        "" => "Dashboard Principal",
        "pos" => "Terminal de ventas",
        "day-status" => "Estado del dia",
        "categories" => "Categorias",
        "products" => "Productos",
        "cash/current" => "Caja",
        "inventory" => "Gestion de inventario",
        "production" => "Produccion",
        "expenses" => "Gastos",
        "analytics" => "Reportes y Analitica",
        "reports/daily" => "Reporte diario",
        "reports/profitability" => "Rentabilidad",
        "cash/history" => "Historial caja",
        "sales/cancellations" => "Historial anulaciones",
        "audit" => "Auditoria",
        "settings" => "Configuracion",
        "users" => "Usuarios",
        _ => "CajaPyme"
    };

    private string CurrentPageIcon => _relativePath switch
    {
        "pos" => "fa-cart-shopping",
        "day-status" => "fa-clipboard-check",
        "categories" => "fa-tags",
        "products" => "fa-box",
        "cash/current" => "fa-cash-register",
        "inventory" => "fa-layer-group",
        "production" => "fa-fire",
        "expenses" => "fa-money-bill-wave",
        "analytics" => "fa-chart-pie",
        "reports/daily" => "fa-chart-line",
        "reports/profitability" => "fa-arrow-trend-up",
        "cash/history" => "fa-receipt",
        "sales/cancellations" => "fa-file-circle-xmark",
        "audit" => "fa-shield-halved",
        "settings" => "fa-gear",
        "users" => "fa-users",
        _ => "fa-gauge-high"
    };

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        UpdateCurrentPath();
        StateHasChanged();
    }

    private void UpdateCurrentPath()
    {
        _relativePath = Navigation
            .ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .Trim('/');
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name
            .Split(['@', '.', ' ', '_', '-'], StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]));

        return string.Concat(parts);
    }
}
